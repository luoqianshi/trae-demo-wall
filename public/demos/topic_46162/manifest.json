{
  "id": "magma-suite",
  "name": "MagmaSuite",
  "version": "2.0.0",
  "minAppVersion": "0.15.0",
  "description": "熔岩套件 - 把《高效能人士的七个习惯》变成 Obsidian 里每天的可执行实现：四象限、打卡、磨刀钟、成就与周报",
  "author": "ShermanGuan",
  "authorUrl": "",
  "fundingUrl": "",
  "isDesktopOnly": false,
  "commands": [
    {
      "id": "create-quadrant-note",
      "name": "创建今日四象限时间管理表",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Shift"],
          "key": "Q"
        }
      ]
    },
    {
      "id": "open-quadrant-note",
      "name": "打开今日四象限时间管理表",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Alt"],
          "key": "Q"
        }
      ]
    },
    {
      "id": "open-quadrant-view",
      "name": "打开四象限交互式视图",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Shift", "Alt"],
          "key": "Q"
        }
      ]
    },
    {
      "id": "open-quadrant-files-view",
      "name": "打开四象限时间管理表列表",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Shift"],
          "key": "L"
        }
      ]
    },
    {
      "id": "open-dashboard",
      "name": "打开工作台",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Shift"],
          "key": "D"
        }
      ]
    },
    {
      "id": "quick-task-inbox",
      "name": "快速收集任务",
      "hotkeys": [
        {
          "modifiers": ["Ctrl", "Shift"],
          "key": "I"
        }
      ]
    }
  ]
}