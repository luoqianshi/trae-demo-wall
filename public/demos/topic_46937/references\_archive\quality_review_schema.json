{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DigitalHandbookQualityReviewSchema",
  "description": "Double-track quality review schema for digital handbooks, locking down engine validation and AIIDE/human semantic reviews.",
  "type": "OBJECT",
  "properties": {
    "schema_version": {
      "type": "STRING",
      "const": "2.3.1"
    },
    "sku": {
      "type": "STRING",
      "description": "The SKU code of the product"
    },
    "audit_timestamp": {
      "type": "STRING",
      "description": "Timestamp of when the audit was performed"
    },
    "engine_review": {
      "type": "OBJECT",
      "required": [
        "total_score",
        "conclusion",
        "metrics",
        "deductions"
      ],
      "properties": {
        "total_score": {
          "type": "NUMBER",
          "minimum": 0,
          "maximum": 100
        },
        "conclusion": {
          "type": "STRING",
          "enum": ["GOLD", "SILVER", "BRONZE", "FAIL"]
        },
        "metrics": {
          "type": "OBJECT",
          "required": [
            "information_density",
            "semantic_quality",
            "visual_alignment",
            "code_hygiene"
          ],
          "properties": {
            "information_density": {
              "type": "OBJECT",
              "required": ["score", "weight", "details"],
              "properties": {
                "score": { "type": "NUMBER" },
                "weight": { "type": "NUMBER" },
                "details": { "type": "STRING" }
              }
            },
            "semantic_quality": {
              "type": "OBJECT",
              "required": ["score", "weight", "details"],
              "properties": {
                "score": { "type": "NUMBER" },
                "weight": { "type": "NUMBER" },
                "details": { "type": "STRING" }
              }
            },
            "visual_alignment": {
              "type": "OBJECT",
              "required": ["score", "weight", "details"],
              "properties": {
                "score": { "type": "NUMBER" },
                "weight": { "type": "NUMBER" },
                "details": { "type": "STRING" }
              }
            },
            "code_hygiene": {
              "type": "OBJECT",
              "required": ["score", "weight", "details"],
              "properties": {
                "score": { "type": "NUMBER" },
                "weight": { "type": "NUMBER" },
                "details": { "type": "STRING" }
              }
            }
          }
        },
        "deductions": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "required": ["section", "rule", "deducted_points", "message"],
            "properties": {
              "section": { "type": "STRING" },
              "rule": { "type": "STRING" },
              "deducted_points": { "type": "NUMBER" },
              "message": { "type": "STRING" }
            }
          }
        }
      }
    },
    "semantic_review": {
      "type": "OBJECT",
      "required": [
        "status",
        "required",
        "reviewed_by",
        "conclusion"
      ],
      "properties": {
        "status": {
          "type": "STRING",
          "enum": ["pending", "done"]
        },
        "required": {
          "type": "BOOLEAN"
        },
        "reviewed_by": {
          "type": "STRING"
        },
        "reviewed_at": {
          "type": "STRING"
        },
        "conclusion": {
          "type": "STRING",
          "enum": ["pending", "pass", "needs_rewrite"]
        },
        "recommended_rewrites": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "required": [
              "section",
              "priority",
              "reason",
              "evidence",
              "suggested_profile",
              "next_action"
            ],
            "properties": {
              "section": { "type": "STRING" },
              "priority": {
                "type": "STRING",
                "enum": ["high", "medium", "low"]
              },
              "reason": { "type": "STRING" },
              "evidence": { "type": "STRING" },
              "suggested_profile": {
                "type": "OBJECT",
                "required": ["quality_profile", "style_profile"],
                "properties": {
                  "quality_profile": { "type": "STRING" },
                  "style_profile": { "type": "STRING" }
                }
              },
              "next_action": { "type": "STRING" }
            }
          }
        }
      }
    },
    "final_delivery_status": {
      "type": "STRING",
      "enum": [
        "engine_failed",
        "engine_pass_semantic_pending",
        "semantic_needs_rewrite",
        "semantic_pass",
        "ready_for_delivery"
      ]
    }
  },
  "required": [
    "schema_version",
    "sku",
    "audit_timestamp",
    "engine_review",
    "semantic_review",
    "final_delivery_status"
  ]
}
