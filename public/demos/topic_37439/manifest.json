{
  "manifest_version": 3,
  "name": "办公久坐提醒 MVP",
  "version": "1.0.0",
  "description": "精准计时 → 智能状态判定 → 弹窗交互的极简久坐提醒扩展",
  "permissions": ["storage", "alarms", "idle", "system.display", "windows", "notifications"],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "久坐提醒",
    "default_icon": {
      "128": "icon.png"
    }
  }
}
