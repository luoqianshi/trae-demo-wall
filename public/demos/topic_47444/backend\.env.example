# === 见澄明 H5 后端环境变量 ===

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/jianchengming
# 或分项配置:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jianchengming
DB_USER=postgres
DB_PASS=your_password

# 豆包大模型 API (火山引擎 Ark)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=Doubao-Seed-2.0-lite
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 微信 OAuth (可选, MVP 阶段可留空)
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# JWT 密钥 (用于用户认证)
JWT_SECRET=your_random_secret_key_change_in_production
