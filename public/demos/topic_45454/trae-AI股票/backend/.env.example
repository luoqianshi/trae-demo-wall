# ===== AI智股 环境变量配置 =====
# 复制本文件为 .env 并按需修改

# 运行环境: development | production
FLASK_ENV=development

# 数据库类型: sqlite | mysql
# sqlite: 零配置，适合本地开发
# mysql:  生产环境推荐
DB_TYPE=sqlite

# MySQL 连接配置（DB_TYPE=mysql 时生效）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_zhigu

# 调试模式
DEBUG=true
SECRET_KEY=ai-zhigu-dev-secret-2026
