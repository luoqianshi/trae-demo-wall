# 衡舟后端代理环境变量配置示例
# 复制本文件为 .env 并填入真实 Key，.env 已被 .gitignore 忽略，不会提交。

# 豆包 / 火山方舟 API Key（主模型，必填）
# 获取方式：登录火山引擎控制台 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 创建 API Key 后复制以 "ark-" 开头的字符串填入下方
DOUBAO_API_KEY=your-doubao-api-key

# DeepSeek API Key（备用模型，可选，留空则仅使用豆包）
# 获取方式：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# 重要：豆包模型需要在火山方舟控制台"开通模型服务"后才能被 API 调用
# 步骤：控制台 → 模型服务 → 搜索模型名 → 点击"开通模型"
#
# 已验证可用的对话模型（账号 2101161090 已开通，2026-06-19 验证）：
#   - doubao-seed-2-0-mini-260428     （默认推荐，最快响应，轻量场景）
#   - doubao-seed-2-0-lite-260428     （全模态理解，质量速度平衡）
#   - doubao-seed-2-0-pro-260215      （Pro版，深度推理最强，速度较慢）
#   - doubao-seed-2-0-lite-260215     （Lite旧版）
#   - doubao-seed-2-0-mini-260215     （Mini旧版）
#   - doubao-seed-1-8-251228          （Seed 1.8）
#   - doubao-seed-1-6-251015          （Seed 1.6）
#   - deepseek-v4-pro-260425          （DeepSeek V4 Pro）
#   - deepseek-v4-flash-260425        （DeepSeek V4 Flash）
#
# Embedding 模型（使用多模态向量化 API /api/v3/embeddings/multimodal）：
#   - doubao-embedding-vision-251215（默认推荐，2048 维，支持纯文本输入）
#   - doubao-embedding-vision-250615（备选，2048 维）
#   注意：纯文本 embedding 模型（doubao-embedding-text-*, doubao-embedding-large-text-*）
#   已进入 Retiring 状态，直接调用返回 404，因此改用多模态 vision 模型。
#   官方文档：https://www.volcengine.com/docs/82379/1523520
#
# 若使用"推理接入点"（ep-* 格式 ID），将接入点 ID 填入前端设置面板的模型位置即可

# 可选：覆盖默认服务商 Base URL
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：生产环境前端可指定独立后端地址
# VITE_API_BASE_URL=https://your-backend.example.com/api

# 代理鉴权与限流
API_TOKEN=your-frontend-access-token
REQUIRE_AUTH=false
RATE_LIMIT_MAX=60
UPSTREAM_TIMEOUT_MS=30000

# Zvec 本地向量库存储配置
# ZVEC_DATA_DIR=./.zvec
# ZVEC_EMBEDDING_DIMENSION=2048
