{
  "name": "hengzhou",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file=.env server/index.mjs",
    "dev:all": "npx concurrently --kill-others --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm:dev:server\" \"npm:dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:static": "npx serve dist -l 5173",
    "build:preview": "npm run build && npm run preview:static",
    "test": "vitest run && node --test server/__tests__/*.test.mjs",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "@zvec/zvec": "^0.5.0",
    "ai": "^6.0.206",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "driver.js": "^1.5.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "expect-type": "^1.2.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
