/**
 * 全局样式文件
 * 定义通用样式变量和基础样式
 */

/* 全局基础样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 32rpx;
  color: #333333;
  background-color: #f5f6fa;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx; /* 为tabBar留出空间 */
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #667eea 0%, #f093fb 100%);
}

/* 圆角卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 大按钮通用样式 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 学科标签颜色 */
.subject-tag-math {
  background-color: #e8f8f0;
  color: #27ae60;
  border: 2rpx solid #27ae60;
}

.subject-tag-chinese {
  background-color: #fdecea;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}

.subject-tag-english {
  background-color: #eaf2fd;
  color: #3498db;
  border: 2rpx solid #3498db;
}

.subject-tag-science {
  background-color: #fef5e7;
  color: #f39c12;
  border: 2rpx solid #f39c12;
}

/* 知识点标签 */
.knowledge-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  color: #666666;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}
