<!--错题详情页 - 单题详情+重做区-->
<view class="page-container" wx:if="{{question}}">

  <!-- 顶部信息栏 -->
  <view class="detail-header">
    <view class="detail-id">第 {{question.id}} 题</view>
    <view class="detail-tags">
      <view class="subject-tag subject-tag-{{question.subject === '数学' ? 'math' : question.subject === '语文' ? 'chinese' : question.subject === '英语' ? 'english' : 'science'}}">
        {{question.subject}}
      </view>
      <view class="knowledge-tag">{{question.knowledgePoint}}</view>
      <view class="wrong-count-badge" wx:if="{{question.wrongCount > 0}}">
        错{{question.wrongCount}}次
      </view>
      <view class="graduated-badge" wx:if="{{question.graduated}}">
        [对] 已毕业
      </view>
    </view>
  </view>

  <!-- 题目内容区 -->
  <view class="question-section card">
    <view class="section-label">[笔] 题目</view>
    <view class="question-content">{{question.question}}</view>
  </view>

  <!-- 我的错误答案 -->
  <view class="my-answer-section card">
    <view class="section-label error-label">[错] 我的答案</view>
    <view class="answer-content error-bg">{{question.myAnswer}}</view>
  </view>

  <!-- 正确答案 -->
  <view class="correct-answer-section card">
    <view class="section-label correct-label">[对] 正确答案</view>
    <view class="answer-content correct-bg">{{question.correctAnswer}}</view>
  </view>

  <!-- 错误原因分析 -->
  <view class="analysis-section card">
    <view class="section-label analysis-label">[灯泡] 错误分析</view>
    <view class="analysis-content analysis-bg">{{question.analysis}}</view>
  </view>

  <!-- 重做区 -->
  <view class="redo-section card">
    <view class="section-label">[笔] 重做一下</view>
    <view class="redo-hint">再试一次，看看是不是真的掌握了！</view>
    <view class="redo-input-wrap">
      <textarea 
        class="redo-input" 
        placeholder="在这里输入你的答案..." 
        value="{{userAnswer}}"
        bindinput="onAnswerInput"
        maxlength="500"
        auto-height
      ></textarea>
    </view>
    <view class="redo-actions">
      <view class="btn-check btn-primary" bindtap="onCheckAnswer">[放大镜] 检查答案</view>
    </view>

    <!-- 检查结果 -->
    <view class="check-result {{checkResult === true ? 'correct' : checkResult === false ? 'wrong' : ''}}" wx:if="{{checkResult !== null}}">
      <view class="check-icon">{{checkResult ? '[庆祝]' : '[加油]'}}</view>
      <view class="check-message">{{checkMessage}}</view>
      <view class="btn-retry" bindtap="onRetry" wx:if="{{!checkResult}}">[刷新] 再试一次</view>
    </view>
  </view>

  <!-- 复习记录 -->
  <view class="review-section card">
    <view class="section-label">[日历] 复习记录</view>
    <view class="review-list">
      <view class="review-item" wx:for="{{question.reviewDates}}" wx:key="index">
        <view class="review-dot"></view>
        <view class="review-text">第 {{index + 1}} 次复习</view>
        <view class="review-date">{{item}}</view>
      </view>
    </view>
    <view class="review-empty" wx:if="{{question.reviewDates.length === 0}}">
      还没有复习记录，快来复习一下吧！
    </view>
  </view>

</view>