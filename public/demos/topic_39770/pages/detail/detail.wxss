/* 错题详情页样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 20rpx 30rpx 60rpx;
}

/* 顶部信息栏 */
.detail-header {
  margin-bottom: 24rpx;
}

.detail-id {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.subject-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.knowledge-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  color: #666666;
  margin-right: 12rpx;
}

.wrong-count-badge {
  font-size: 24rpx;
  color: #e74c3c;
  background: #fdecea;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.graduated-badge {
  font-size: 24rpx;
  color: #27ae60;
  background: #e8f8f0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 通用section标签 */
.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.error-label {
  color: #e74c3c;
}

.correct-label {
  color: #27ae60;
}

.analysis-label {
  color: #f39c12;
}

/* 题目内容 */
.question-content {
  font-size: 34rpx;
  line-height: 1.8;
  color: #333333;
}

/* 答案区域 */
.answer-content {
  font-size: 32rpx;
  line-height: 1.6;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.error-bg {
  background-color: #fdecea;
  color: #c0392b;
}

.correct-bg {
  background-color: #e8f8f0;
  color: #1e8449;
}

/* 错误分析 */
.analysis-content {
  font-size: 30rpx;
  line-height: 1.8;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background-color: #fef9e7;
  color: #7d6608;
  white-space: pre-wrap;
}

/* 重做区 */
.redo-section {
  margin-top: 0;
}

.redo-hint {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.redo-input-wrap {
  margin-bottom: 20rpx;
}

.redo-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 32rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.redo-actions {
  margin-bottom: 20rpx;
}

.btn-check {
  width: 100%;
}

/* 检查结果 */
.check-result {
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  animation: fadeIn 0.3s ease;
}

.check-result.correct {
  background: #e8f8f0;
  border: 2rpx solid #27ae60;
}

.check-result.wrong {
  background: #fdecea;
  border: 2rpx solid #e74c3c;
}

.check-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.check-message {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.btn-retry {
  display: inline-block;
  padding: 12rpx 40rpx;
  background: #ffffff;
  border: 2rpx solid #e74c3c;
  color: #e74c3c;
  border-radius: 32rpx;
  font-size: 28rpx;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 复习记录 */
.review-list {
  padding-left: 20rpx;
}

.review-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #f093fb);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.review-text {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.review-date {
  font-size: 26rpx;
  color: #999999;
}

.review-empty {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 20rpx 0;
}
