/** 我的页面样式 */
.page-container {
  padding-bottom: 60rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  text-align: center;
  padding: 60rpx 40rpx;
  color: white;
}

.avatar {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-grade {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 15rpx;
}

.user-streak {
  font-size: 26rpx;
  background: rgba(255,255,255,0.2);
  display: inline-block;
  padding: 8rpx 25rpx;
  border-radius: 30rpx;
}

/* 学习统计 */
.section {
  margin: 30rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-num.graduated {
  color: #27ae60;
}

.stat-label {
  font-size: 26rpx;
  color: #7f8c8d;
}

/* 功能菜单 */
.menu-list {
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #2c3e50;
}

.menu-arrow {
  font-size: 36rpx;
  color: #bdc3c7;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #95a5a6;
  font-size: 24rpx;
  line-height: 1.8;
}
