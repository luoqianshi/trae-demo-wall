<!--我的页面 - 个人信息+设置-->
<view class="page-container">

  <!-- 用户信息卡片 -->
  <view class="user-card gradient-bg">
    <view class="avatar">[头像]</view>
    <view class="user-name">小明同学</view>
    <view class="user-grade">小学五年级</view>
    <view class="user-streak">[火] 连续打卡 7 天</view>
  </view>

  <!-- 学习统计 -->
  <view class="section">
    <view class="section-title">[图] 学习统计</view>
    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-num">{{stats.total}}</view>
        <view class="stat-label">总错题数</view>
      </view>
      <view class="stat-card">
        <view class="stat-num graduated">{{stats.graduated}}</view>
        <view class="stat-label">已毕业</view>
      </view>
      <view class="stat-card">
        <view class="stat-num">{{stats.notGraduated}}</view>
        <view class="stat-label">待复习</view>
      </view>
      <view class="stat-card">
        <view class="stat-num">{{stats.subjects.length}}</view>
        <view class="stat-label">覆盖学科</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="section-title">[设置] 功能设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onTapSetting" data-type="subjects">
        <view class="menu-left">
          <view class="menu-icon">[书]</view>
          <view class="menu-text">管理学科</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" bindtap="onTapSetting" data-type="tags">
        <view class="menu-left">
          <view class="menu-icon">[标签]</view>
          <view class="menu-text">知识点标签</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" bindtap="onTapSetting" data-type="export">
        <view class="menu-left">
          <view class="menu-icon">[导出]</view>
          <view class="menu-text">导出数据</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" bindtap="onTapSetting" data-type="about">
        <view class="menu-left">
          <view class="menu-icon">[信息]</view>
          <view class="menu-text">关于我们</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <view>错题整理小能手 v1.0.0</view>
    <view>TRAE AI 创造力大赛参赛作品</view>
  </view>

</view>