/* 错题本预览页样式 */

.page-container {
  min-height: 100vh;
  background-color: #e8e8e8;
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* A4纸效果 */
.paper {
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

/* 封面区域 */
.paper-cover {
  background: linear-gradient(135deg, #667eea 0%, #f093fb 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.cover-decoration {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.cover-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.cover-divider {
  width: 120rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  margin: 0 auto 30rpx;
  border-radius: 2rpx;
}

.cover-info {
  margin-bottom: 24rpx;
}

.cover-info-item {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.cover-motto {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-style: italic;
  margin-top: 16rpx;
}

/* 错题内容区 */
.paper-content {
  padding: 40rpx;
}

.content-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eeeeee;
}

/* 单题预览 */
.preview-question {
  margin-bottom: 20rpx;
}

.pq-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.pq-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 16rpx;
}

.pq-subject {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.pq-subject-math {
  background: #e8f8f0;
  color: #27ae60;
}

.pq-subject-chinese {
  background: #fdecea;
  color: #e74c3c;
}

.pq-subject-english {
  background: #eaf2fd;
  color: #3498db;
}

.pq-subject-science {
  background: #fef5e7;
  color: #f39c12;
}

.pq-body {
  padding-left: 16rpx;
}

.pq-section {
  margin-bottom: 16rpx;
}

.pq-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 8rpx;
}

.pq-label-error {
  color: #e74c3c;
}

.pq-label-correct {
  color: #27ae60;
}

.pq-label-analysis {
  color: #f39c12;
}

.pq-text {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background: #f8f9fa;
}

.pq-text-error {
  background: #fdecea;
  color: #c0392b;
}

.pq-text-correct {
  background: #e8f8f0;
  color: #1e8449;
}

.pq-text-analysis {
  background: #fef9e7;
  color: #7d6608;
  font-size: 28rpx;
  white-space: pre-wrap;
}

.pq-divider {
  height: 2rpx;
  background: #eeeeee;
  margin: 30rpx 0;
}

/* 更多提示 */
.more-hint {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  padding: 30rpx 0;
  border-top: 2rpx dashed #dddddd;
  margin-top: 20rpx;
}

/* 底部操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 20rpx;
  z-index: 100;
}

.btn-pdf {
  flex: 1;
}

.btn-share {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  background: #ffffff;
  border: 2rpx solid #667eea;
  border-radius: 48rpx;
}

.btn-share:active {
  opacity: 0.9;
  transform: scale(0.98);
}
