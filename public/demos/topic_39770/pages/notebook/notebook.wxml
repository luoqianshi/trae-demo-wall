<!--错题本预览页 - 打印预览效果-->
<view class="page-container">

  <!-- A4纸预览 -->
  <view class="paper">

    <!-- 封面区域 -->
    <view class="paper-cover">
      <view class="cover-decoration">[书]</view>
      <view class="cover-title">{{notebookTitle}}</view>
      <view class="cover-divider"></view>
      <view class="cover-info">
        <view class="cover-info-item">[人] 姓名：{{studentName}}</view>
        <view class="cover-info-item">[日历] 日期：{{dateStr}}</view>
        <view class="cover-info-item">[笔] 共 {{totalCount}} 道错题</view>
      </view>
      <view class="cover-motto">错题是进步的阶梯，每天进步一点点！</view>
    </view>

    <!-- 错题预览 -->
    <view class="paper-content">
      <view class="content-title">错题内容</view>

      <view 
        class="preview-question"
        wx:for="{{previewQuestions}}"
        wx:key="id"
      >
        <view class="pq-header">
          <view class="pq-number">第{{item.id}}题</view>
          <view class="pq-tags">
            <view class="pq-subject pq-subject-{{item.subject === '数学' ? 'math' : item.subject === '语文' ? 'chinese' : item.subject === '英语' ? 'english' : 'science'}}">
              {{item.subject}} - {{item.knowledgePoint}}
            </view>
          </view>
        </view>
        <view class="pq-body">
          <view class="pq-section">
            <view class="pq-label">题目：</view>
            <view class="pq-text">{{item.question}}</view>
          </view>
          <view class="pq-section">
            <view class="pq-label pq-label-error">我的答案：</view>
            <view class="pq-text pq-text-error">{{item.myAnswer}}</view>
          </view>
          <view class="pq-section">
            <view class="pq-label pq-label-correct">正确答案：</view>
            <view class="pq-text pq-text-correct">{{item.correctAnswer}}</view>
          </view>
          <view class="pq-section">
            <view class="pq-label pq-label-analysis">分析：</view>
            <view class="pq-text pq-text-analysis">{{item.analysis}}</view>
          </view>
        </view>
        <!-- 分隔线 -->
        <view class="pq-divider" wx:if="{{index < previewQuestions.length - 1}}"></view>
      </view>

      <!-- 更多提示 -->
      <view class="more-hint" wx:if="{{totalCount > 3}}">
        ... 还有 {{totalCount - 3}} 道错题，完整版请生成PDF查看 ...
      </view>
    </view>

  </view>

  <!-- 底部操作按钮 -->
  <view class="action-buttons">
    <view class="btn-pdf btn-primary" bindtap="onGeneratePDF">
      [文件] 生成PDF
    </view>
    <view class="btn-share" bindtap="onShareToParent">
      [分享] 分享给家长
    </view>
  </view>

</view>