/* 错题列表页样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 140rpx;
}

/* Tab切换栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 20rpx 20rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999999;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
  font-size: 30rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #f093fb);
  border-radius: 3rpx;
}

/* 错题列表 */
.wrong-list {
  padding: 0 30rpx;
}

.wrong-item {
  margin-bottom: 20rpx;
  transition: transform 0.2s;
}

.wrong-item:active {
  transform: scale(0.98);
}

.wrong-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.wrong-tags {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.subject-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.wrong-count-badge {
  font-size: 24rpx;
  color: #e74c3c;
  background: #fdecea;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.graduated-badge {
  font-size: 24rpx;
  color: #27ae60;
  background: #e8f8f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.wrong-question {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.wrong-item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-info {
  font-size: 24rpx;
  color: #999999;
}

.arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 28rpx;
  color: #999999;
}

/* 底部浮动按钮 */
.float-btn {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
}

.float-btn:active {
  opacity: 0.9;
  transform: translateX(-50%) scale(0.96);
}

.float-btn-icon {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.float-btn-text {
  font-size: 30rpx;
  font-weight: bold;
}
