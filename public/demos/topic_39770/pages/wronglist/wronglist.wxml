<!--错题列表页 - 按学科分类展示-->
<view class="page-container">

  <!-- Tab切换栏 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      <text wx:if="{{index === 0}}">[列表]</text>
      <text wx:if="{{index === 1}}">[数]</text>
      <text wx:if="{{index === 2}}">[语]</text>
      <text wx:if="{{index === 3}}">[英]</text>
      <text wx:if="{{index === 4}}">[科]</text>
      {{item}}
    </view>
  </view>

  <!-- 错题列表 -->
  <view class="wrong-list" wx:if="{{!isEmpty}}">
    <view 
      class="wrong-item card"
      wx:for="{{filteredList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onItemTap"
    >
      <!-- 顶部标签行 -->
      <view class="wrong-item-header">
        <view class="wrong-tags">
          <view class="subject-tag subject-tag-{{item.subject === '数学' ? 'math' : item.subject === '语文' ? 'chinese' : item.subject === '英语' ? 'english' : 'science'}}">
            {{item.subject}}
          </view>
          <view class="knowledge-tag">{{item.knowledgePoint}}</view>
        </view>
        <!-- 错误次数badge -->
        <view class="wrong-count-badge" wx:if="{{item.wrongCount > 0}}">
          错{{item.wrongCount}}次
        </view>
        <!-- 毕业勋章 -->
        <view class="graduated-badge" wx:if="{{item.graduated}}">
          [对] 已毕业
        </view>
      </view>

      <!-- 题目内容（截断显示） -->
      <view class="wrong-question">{{item.question}}</view>

      <!-- 底部信息 -->
      <view class="wrong-item-footer">
        <view class="review-info">
          已复习 {{item.reviewDates.length}} 次
        </view>
        <view class="arrow">-</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">[庆祝]</view>
    <view class="empty-text">太棒了！这里没有错题</view>
    <view class="empty-sub">继续保持，加油！</view>
  </view>

  <!-- 底部浮动添加按钮 -->
  <view class="float-btn" bindtap="onAddWrong">
    <text class="float-btn-icon">+</text>
    <text class="float-btn-text">手动添加错题</text>
  </view>

</view>