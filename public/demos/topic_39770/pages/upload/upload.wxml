<!--上传页 - 拍照/相册选取 + AI识别流程-->
<view class="page-container">

  <!-- 阶段一：选择上传方式 -->
  <view class="choose-section" wx:if="{{stage === 'choose'}}">
    <view class="choose-title">请选择上传试卷的方式</view>
    <view class="choose-sub">将试卷拍照或从相册中选取照片</view>

    <!-- 两个大按钮 -->
    <view class="choose-grid">
      <!-- 拍照按钮 -->
      <view class="choose-card" bindtap="onTakePhoto">
        <view class="choose-icon-wrap camera-bg">
          <view class="choose-icon-text">[相机]</view>
        </view>
        <view class="choose-card-title">拍试卷</view>
        <view class="choose-card-desc">调用摄像头拍照</view>
      </view>

      <!-- 相册按钮 -->
      <view class="choose-card" bindtap="onPickFromAlbum">
        <view class="choose-icon-wrap album-bg">
          <view class="choose-icon-text">[相册]</view>
        </view>
        <view class="choose-card-title">从相册选取</view>
        <view class="choose-card-desc">选取已有照片</view>
      </view>
    </view>

    <!-- 提示 -->
    <view class="choose-tip">
      <view class="tip-icon">!</view>
      <view class="tip-text">拍照时请对准试卷题目，确保文字清晰可见</view>
    </view>
  </view>

  <!-- 阶段二：预览照片 -->
  <view class="preview-section" wx:if="{{stage === 'preview'}}">
    <view class="preview-title">照片预览</view>

    <!-- 图片预览 -->
    <view class="preview-image-wrap">
      <image class="preview-image" src="{{imagePath}}" mode="aspectFit"></image>
    </view>

    <!-- 操作按钮 -->
    <view class="preview-actions">
      <view class="btn-back" bindtap="onReselect">重新选择</view>
      <view class="btn-recognize btn-primary" bindtap="onStartRecognize">
        开始AI识别
      </view>
    </view>
  </view>

  <!-- 阶段三：识别中 -->
  <view class="recognizing-section" wx:if="{{stage === 'recognizing'}}">
    <view class="recognize-icon">[放大镜]</view>
    <view class="recognize-title">正在识别中...</view>
    <view class="recognize-sub">AI正在帮你找出做错的题目</view>

    <!-- 进度条 -->
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{recognizeProgress}}%;"></view>
    </view>
    <view class="progress-text">{{recognizeProgress}}%</view>
  </view>

  <!-- 阶段四：识别结果 -->
  <view class="result-section" wx:if="{{stage === 'result'}}">
    <view class="result-header">
      <view class="result-title">识别结果</view>
      <view class="result-count">共识别 {{recognizeResults.length}} 道题</view>
    </view>

    <!-- 识别结果列表 -->
    <view class="result-list">
      <view
        class="result-item card {{item.isWrong ? 'selected' : ''}}"
        wx:for="{{recognizeResults}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="onToggleWrong"
      >
        <view class="result-item-left">
          <view class="result-number">第{{item.number}}题</view>
          <view class="result-tags">
            <view class="subject-tag subject-tag-{{item.subject === '数学' ? 'math' : 'chinese'}}">
              {{item.subject}}
            </view>
            <view class="knowledge-tag">{{item.knowledgePoint}}</view>
          </view>
          <view class="result-question">{{item.question}}</view>
          <view class="result-status">
            <text wx:if="{{item.recognized}}">[对] 已识别</text>
            <text wx:else>! 需确认</text>
          </view>
        </view>
        <view class="result-checkbox {{item.isWrong ? 'checked' : ''}}">
          <text wx:if="{{item.isWrong}}">[V]</text>
        </view>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="result-actions">
      <view class="btn-retake" bindtap="onReselect">[相机] 重新选择</view>
      <view class="btn-confirm btn-primary" bindtap="onConfirmAdd">
        [对] 确认并添加到错题本 ({{selectedCount}}道)
      </view>
    </view>
  </view>

</view>