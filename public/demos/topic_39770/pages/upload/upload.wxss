/* 上传页样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 30rpx;
}

/* ========== 阶段一：选择上传方式 ========== */
.choose-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.choose-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.choose-sub {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.choose-grid {
  display: flex;
  gap: 30rpx;
  width: 100%;
  margin-bottom: 50rpx;
}

.choose-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.choose-card:active {
  transform: scale(0.97);
  opacity: 0.8;
}

.choose-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.camera-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.album-bg {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.choose-icon-text {
  font-size: 56rpx;
  color: #ffffff;
}

.choose-card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.choose-card-desc {
  font-size: 24rpx;
  color: #999999;
}

.choose-tip {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
  border-left: 6rpx solid #667eea;
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #667eea;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* ========== 阶段二：预览照片 ========== */
.preview-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.preview-image-wrap {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.preview-image {
  width: 100%;
  height: 800rpx;
  border-radius: 16rpx;
}

.preview-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
  background: #ffffff;
  border-radius: 44rpx;
  border: 2rpx solid #eeeeee;
}

.btn-recognize {
  flex: 2;
}

/* ========== 阶段三：识别中 ========== */
.recognizing-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 800rpx;
}

.recognize-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.recognize-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.recognize-sub {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

/* 进度条 */
.progress-bar {
  width: 500rpx;
  height: 16rpx;
  background-color: #eeeeee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #f093fb 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

/* ========== 阶段四：识别结果 ========== */
.result-section {
  padding-bottom: 40rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.result-count {
  font-size: 26rpx;
  color: #999999;
}

.result-list {
  margin-bottom: 30rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.result-item.selected {
  border-left: 6rpx solid #667eea;
}

.result-item-left {
  flex: 1;
}

.result-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.subject-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.result-question {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.result-status {
  font-size: 24rpx;
  color: #27ae60;
}

.result-checkbox {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.result-checkbox.checked {
  background-color: #667eea;
  border-color: #667eea;
}

/* 底部操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-retake {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666666;
  background: #ffffff;
  border-radius: 44rpx;
  border: 2rpx solid #eeeeee;
}

.btn-confirm {
  margin-top: 0;
}
