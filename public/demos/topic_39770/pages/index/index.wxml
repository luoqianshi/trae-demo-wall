<!--首页 - 错题整理小能手-->
<view class="page-container">

  <!-- 顶部欢迎区域 -->
  <view class="header gradient-bg">
    <view class="header-content">
      <view class="greeting">Hi, 小明同学！</view>
      <view class="sub-greeting">今天学习了什么？</view>
      <view class="date-info">{{dateStr}} {{weekDay}}</view>
    </view>
    <view class="header-decoration">[书]</view>
  </view>

  <!-- 4大功能入口 -->
  <view class="section">
    <view class="section-title">[星] 快捷功能</view>
    <view class="menu-grid">
      <view 
        class="menu-card" 
        wx:for="{{menuList}}" 
        wx:key="title"
        data-index="{{index}}"
        bindtap="onMenuTap"
        style="background-color: {{item.bgColor}};"
      >
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-title" style="color: {{item.color}};">{{item.title}}</view>
        <view class="menu-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <!-- 今日学习统计 -->
  <view class="section">
    <view class="section-title">[图] 今日学习</view>
    <view class="stats-card card">
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-number">{{todayCount}}</view>
          <view class="stat-label">已整理错题</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-number graduated">{{graduatedCount}}</view>
          <view class="stat-label">已毕业错题</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-number consecutive">{{consecutiveDays}}</view>
          <view class="stat-label">连续打卡(天)</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部激励语 -->
  <view class="motivation">
    <view class="motivation-text">[星] 每一道错题，都是通往满分的台阶 [星]</view>
  </view>

</view>