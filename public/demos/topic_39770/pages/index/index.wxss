/* 首页样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 40rpx;
}

/* 顶部欢迎区域 */
.header {
  padding: 60rpx 40rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 1;
}

.greeting {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.sub-greeting {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.date-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.header-decoration {
  position: absolute;
  right: 40rpx;
  top: 50rpx;
  font-size: 80rpx;
  opacity: 0.3;
}

/* 通用section */
.section {
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 功能入口网格 */
.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.menu-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.menu-card:active {
  transform: scale(0.96);
}

.menu-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.menu-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #667eea;
  line-height: 1.2;
}

.stat-number.graduated {
  color: #27ae60;
}

.stat-number.consecutive {
  color: #f39c12;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #eeeeee;
}

/* 底部激励语 */
.motivation {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.motivation-text {
  font-size: 28rpx;
  color: #999999;
  font-style: italic;
}
