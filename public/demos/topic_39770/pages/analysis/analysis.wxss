/* 薄弱点分析页样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.page-header {
  padding: 30rpx 30rpx 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 图表区域 */
.chart-section {
  margin: 20rpx 30rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.chart-canvas {
  width: 100%;
}

/* 无数据提示 */
.no-data {
  margin: 20rpx 30rpx;
  text-align: center;
  padding: 60rpx 30rpx;
}

.no-data-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-data-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.no-data-sub {
  font-size: 28rpx;
  color: #999999;
}

/* 详细建议区域 */
.detail-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 建议卡片 */
.advice-card {
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.advice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.advice-rank {
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
  background: linear-gradient(135deg, #667eea, #f093fb);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.advice-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.advice-subject {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.advice-count {
  margin-bottom: 16rpx;
}

.count-number {
  font-size: 48rpx;
  font-weight: bold;
}

.count-label {
  font-size: 28rpx;
  color: #999999;
}

.advice-suggestion {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #fffbe6;
  border-radius: 16rpx;
}

.advice-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  border-radius: 40rpx;
}

.advice-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
