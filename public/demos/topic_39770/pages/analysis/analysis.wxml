<!--薄弱点分析页 - TOP5图表+详细建议-->
<view class="page-container">

  <!-- 顶部标题 -->
  <view class="page-header">
    <view class="page-title">[图] 我的薄弱知识点</view>
    <view class="page-subtitle">找到弱点，逐个击破！</view>
  </view>

  <!-- TOP5柱状图 -->
  <view class="chart-section card" wx:if="{{weakPoints.length > 0}}">
    <view class="chart-title">TOP5 薄弱知识点</view>
    <canvas 
      type="2d" 
      id="chartCanvas" 
      class="chart-canvas"
      style="width: 100%; height: {{weakPoints.length * 60 + 30}}px;"
    ></canvas>
  </view>

  <!-- 无数据提示 -->
  <view class="no-data card" wx:if="{{weakPoints.length === 0}}">
    <view class="no-data-icon">[庆祝]</view>
    <view class="no-data-text">暂无薄弱知识点</view>
    <view class="no-data-sub">所有错题都已毕业，太厉害了！</view>
  </view>

  <!-- 薄弱知识点详细卡片 -->
  <view class="detail-section" wx:if="{{weakPoints.length > 0}}">
    <view class="section-title">[灯泡] 针对性建议</view>
    <view 
      class="advice-card card"
      wx:for="{{weakPoints}}"
      wx:key="name"
    >
      <view class="advice-header">
        <view class="advice-rank">TOP{{index + 1}}</view>
        <view class="advice-name">{{item.name}}</view>
        <view class="advice-subject" style="color: {{item.color}}; background: {{item.color}}15;">
          {{item.subject}}
        </view>
      </view>
      <view class="advice-count">
        <text class="count-number" style="color: {{item.color}};">{{item.count}}</text>
        <text class="count-label"> 次错误</text>
      </view>
      <view class="advice-suggestion">
        [灯泡] {{item.suggestion}}
      </view>
      <view 
        class="advice-btn"
        style="background: {{item.color}};"
        data-index="{{index}}"
        bindtap="onPractice"
      >
        [目标] 开始练习
      </view>
    </view>
  </view>

</view>