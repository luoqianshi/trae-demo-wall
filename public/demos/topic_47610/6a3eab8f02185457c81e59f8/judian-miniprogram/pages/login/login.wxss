.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 60rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
}

.logo-gradient {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
}

.brand-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
}

.glass-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 48rpx 36rpx;
  box-sizing: border-box;
}

.form-card {
  margin-top: 20rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  line-height: 1;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
  height: 48rpx;
  line-height: 48rpx;
}

.placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.form-links {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.link-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
}

.btn-gradient {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.btn-gradient::after {
  border: none;
}

.login-btn {
  margin-bottom: 40rpx;
}

.quick-login-section {
  margin-top: 20rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.15);
}

.divider-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 0 20rpx;
}

.quick-btns {
  display: flex;
  justify-content: center;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  width: 120rpx;
  height: 120rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 0;
  margin: 0;
}

.quick-btn::after {
  border: none;
}

.quick-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.quick-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}
