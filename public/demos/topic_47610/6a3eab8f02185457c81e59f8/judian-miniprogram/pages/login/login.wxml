<view class="login-page">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 品牌区域 -->
  <view class="brand-section">
    <view class="logo-gradient">JU</view>
    <view class="brand-title">聚点</view>
    <view class="brand-subtitle">连接每一个精彩瞬间</view>
  </view>

  <!-- 登录表单卡片 -->
  <view class="glass-card form-card">
    <view class="input-group">
      <text class="input-icon">📱</text>
      <input
        type="number"
        class="input-field"
        placeholder="请输入手机号"
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="input-group">
      <text class="input-icon">🔒</text>
      <input
        type="text"
        password="{{true}}"
        class="input-field"
        placeholder="请输入密码"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 忘记密码 / 注册 -->
    <view class="form-links">
      <text class="link-text" bindtap="onForgotPassword">忘记密码?</text>
      <text class="link-text" bindtap="onGoRegister">立即注册</text>
    </view>

    <!-- 登录按钮 -->
    <button class="btn-gradient login-btn" bindtap="onLogin">登 录</button>

    <!-- 快捷登录 -->
    <view class="quick-login-section">
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">快捷登录</text>
        <view class="divider-line"></view>
      </view>
      <view class="quick-btns">
        <button class="quick-btn wechat-btn" open-type="getPhoneNumber" bindgetphonenumber="onWechatLogin">
          <text class="quick-icon">💬</text>
          <text class="quick-label">微信</text>
        </button>
      </view>
    </view>
  </view>
</view>
