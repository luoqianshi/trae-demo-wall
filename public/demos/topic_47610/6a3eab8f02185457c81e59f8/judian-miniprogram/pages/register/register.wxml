<view class="register-page">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 返回按钮 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onGoBack">
      <text class="back-icon">←</text>
    </view>
  </view>

  <!-- 标题区域 -->
  <view class="header-section">
    <view class="header-title">创建账号</view>
    <view class="header-subtitle">加入聚点，发现更多精彩</view>
  </view>

  <!-- 注册表单卡片 -->
  <view class="glass-card form-card">
    <view class="input-group">
      <text class="input-icon">👤</text>
      <input
        type="text"
        class="input-field"
        placeholder="请输入昵称"
        placeholder-class="placeholder"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="input-group">
      <text class="input-icon">📱</text>
      <input
        type="number"
        class="input-field"
        placeholder="请输入手机号"
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="input-group code-group">
      <text class="input-icon">🔢</text>
      <input
        type="number"
        class="input-field code-input"
        placeholder="请输入验证码"
        placeholder-class="placeholder"
        value="{{code}}"
        bindinput="onCodeInput"
        maxlength="6"
      />
      <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="onSendCode">
        <text class="code-btn-text">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
      </view>
    </view>

    <view class="input-group">
      <text class="input-icon">🔒</text>
      <input
        type="text"
        password="{{true}}"
        class="input-field"
        placeholder="请设置密码（至少6位）"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 同意协议 -->
    <view class="agreement-section">
      <view class="checkbox {{agree ? 'checked' : ''}}" bindtap="onToggleAgree">
        <text wx:if="{{agree}}" class="check-icon">✓</text>
      </view>
      <view class="agreement-text">
        <text class="text-normal">我已阅读并同意</text>
        <text class="text-link" bindtap="onViewAgreement">《用户协议》</text>
        <text class="text-normal">和</text>
        <text class="text-link" bindtap="onViewPrivacy">《隐私政策》</text>
      </view>
    </view>

    <!-- 注册按钮 -->
    <button class="btn-gradient register-btn" bindtap="onRegister">立即注册</button>

    <!-- 去登录 -->
    <view class="login-link-row">
      <text class="text-normal">已有账号？</text>
      <text class="text-link" bindtap="onGoLogin">立即登录</text>
    </view>
  </view>
</view>
