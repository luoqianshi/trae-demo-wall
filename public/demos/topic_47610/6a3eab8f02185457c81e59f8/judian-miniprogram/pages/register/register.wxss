.register-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  display: flex;
  flex-direction: column;
  padding: 0 40rpx 60rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  margin-bottom: 20rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.back-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
}

.header-section {
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
}

.glass-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 48rpx 36rpx;
  box-sizing: border-box;
}

.form-card {
  margin-top: 10rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  line-height: 1;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
  height: 48rpx;
  line-height: 48rpx;
}

.placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.code-group {
  padding-right: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  margin-left: 16rpx;
}

.code-btn.disabled {
  background: rgba(255, 255, 255, 0.15);
}

.code-btn-text {
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
}

.agreement-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  margin-top: 8rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 16rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.check-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: bold;
}

.agreement-text {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.text-normal {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

.text-link {
  font-size: 24rpx;
  color: #667eea;
  line-height: 1.6;
}

.btn-gradient {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.btn-gradient::after {
  border: none;
}

.register-btn {
  margin-bottom: 32rpx;
}

.login-link-row {
  display: flex;
  justify-content: center;
  align-items: center;
}
