page {
  background-color: #f5f6fa;
}

.profile-container {
  padding: 0 32rpx 40rpx;
}

/* 状态栏 */
.status-bar {
  width: 100%;
}

/* 用户信息区 */
.user-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b6b, #ff8e53);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.badge-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #eee;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 热门设置 */
.hot-settings-section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.settings-scroll-wrapper {
  width: 100%;
}

.settings-row {
  display: flex;
  flex-direction: row;
  width: 100%;
}

.setting-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.setting-card:last-child {
  margin-right: 0;
}

.setting-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 8rpx;
}

.setting-label {
  font-size: 24rpx;
  color: #888;
}
