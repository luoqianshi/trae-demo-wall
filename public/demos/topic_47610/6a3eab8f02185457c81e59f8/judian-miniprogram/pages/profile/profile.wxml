<view class="profile-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- 用户信息区 -->
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
      <view class="badge">
        <image class="badge-icon" src="/images/icon-badge.png" mode="aspectFit" />
        <text class="badge-text">高频组织者</text>
      </view>
    </view>
  </view>

  <!-- 统计数据卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">28</text>
      <text class="stat-label">组队次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">36</text>
      <text class="stat-label">收藏地点</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">安静自习</text>
      <text class="stat-label">常用偏好</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToPage" data-url="/pages/my-groups/my-groups">
      <image class="menu-icon" src="/images/icon-groups.png" mode="aspectFit" />
      <text class="menu-text">我的组队</text>
      <image class="arrow-icon" src="/images/icon-arrow.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/favorites/favorites">
      <image class="menu-icon" src="/images/icon-fav.png" mode="aspectFit" />
      <text class="menu-text">收藏地点</text>
      <image class="arrow-icon" src="/images/icon-arrow.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/preferences/preferences">
      <image class="menu-icon" src="/images/icon-pref.png" mode="aspectFit" />
      <text class="menu-text">常用偏好</text>
      <image class="arrow-icon" src="/images/icon-arrow.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="inviteFriend">
      <image class="menu-icon" src="/images/icon-invite.png" mode="aspectFit" />
      <text class="menu-text">邀请好友</text>
      <image class="arrow-icon" src="/images/icon-arrow.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/settings/settings">
      <image class="menu-icon" src="/images/icon-setting.png" mode="aspectFit" />
      <text class="menu-text">设置</text>
      <image class="arrow-icon" src="/images/icon-arrow.png" mode="aspectFit" />
    </view>
  </view>

  <!-- 热门设置横向滚动 -->
  <view class="hot-settings-section">
    <view class="section-title">热门设置</view>
    <view class="settings-scroll-wrapper">
      <view class="settings-row">
        <view class="setting-card">
          <text class="setting-value">4.8</text>
          <text class="setting-label">预算</text>
        </view>
        <view class="setting-card">
          <text class="setting-value">1.2km</text>
          <text class="setting-label">交通</text>
        </view>
        <view class="setting-card">
          <text class="setting-value">轻松</text>
          <text class="setting-label">氛围</text>
        </view>
      </view>
    </view>
  </view>
</view>
