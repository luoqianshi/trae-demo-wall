page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 状态栏 */
.status-bar {
  background-color: #ffffff;
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
}

.nav-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.nav-placeholder {
  width: 60rpx;
}

/* 筛选标签区 */
.filter-section {
  background-color: #ffffff;
  padding-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background-color: #f5f6fa;
  border: 2rpx solid transparent;
}

.tag-active {
  background-color: #667eea;
  border-color: #667eea;
}

.tag-text {
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
}

.tag-active .tag-text {
  color: #ffffff;
  font-weight: 600;
}

/* 场地列表 */
.venue-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.venue-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.venue-selected {
  border-color: #667eea;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.15);
}

.venue-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.venue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.venue-header {
  margin-bottom: 12rpx;
}

.venue-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.venue-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stars {
  display: flex;
}

.star {
  font-size: 24rpx;
  color: #ffc107;
  margin-right: 2rpx;
}

.star-empty {
  font-size: 24rpx;
  color: #e0e0e0;
  margin-right: 2rpx;
}

.venue-distance {
  font-size: 22rpx;
  color: #888888;
}

.venue-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.venue-tag {
  font-size: 20rpx;
  color: #667eea;
  background-color: rgba(102, 126, 234, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 进度条 */
.match-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.match-track {
  flex: 1;
  height: 10rpx;
  background-color: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}

.match-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.match-text {
  font-size: 20rpx;
  color: #667eea;
  font-weight: 600;
  flex-shrink: 0;
}

/* 选择框 */
.select-box {
  margin-left: 20rpx;
  flex-shrink: 0;
}

.select-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.select-circle-active {
  background-color: #667eea;
  border-color: #667eea;
}

.select-check {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.list-footer {
  height: 160rpx;
}

/* 底部确认按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 40rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.confirm-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 30rpx;
  bottom: 180rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(245, 87, 108, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.fab-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
}
