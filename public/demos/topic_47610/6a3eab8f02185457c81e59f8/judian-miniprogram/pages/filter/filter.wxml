<view class="container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="nav-left" bindtap="goBack">
      <text class="nav-back-icon">&#60;</text>
    </view>
    <text class="nav-title">筛选候选地</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 筛选标签区 -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
      <view class="filter-tags">
        <view class="tag {{activeTag === 'distance' ? 'tag-active' : ''}}" data-tag="distance" bindtap="switchTag">
          <text class="tag-text">距离最近</text>
        </view>
        <view class="tag {{activeTag === 'budget' ? 'tag-active' : ''}}" data-tag="budget" bindtap="switchTag">
          <text class="tag-text">预算匹配</text>
        </view>
        <view class="tag {{activeTag === 'vibe' ? 'tag-active' : ''}}" data-tag="vibe" bindtap="switchTag">
          <text class="tag-text">氛围契合</text>
        </view>
        <view class="tag {{activeTag === 'traffic' ? 'tag-active' : ''}}" data-tag="traffic" bindtap="switchTag">
          <text class="tag-text">交通便利</text>
        </view>
        <view class="tag {{activeTag === 'facility' ? 'tag-active' : ''}}" data-tag="facility" bindtap="switchTag">
          <text class="tag-text">设施完善</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 场地列表 -->
  <scroll-view class="venue-list" scroll-y="true">
    <view class="venue-card {{item.selected ? 'venue-selected' : ''}}" wx:for="{{venues}}" wx:key="id" data-id="{{item.id}}" bindtap="selectVenue">
      <image class="venue-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="venue-info">
        <view class="venue-header">
          <text class="venue-name">{{item.name}}</text>
          <view class="venue-meta">
            <view class="stars">
              <text class="star" wx:for="{{item.stars}}" wx:for-item="star" wx:key="index">★</text>
              <text class="star-empty" wx:for="{{5 - item.stars}}" wx:for-item="star" wx:key="index">★</text>
            </view>
            <text class="venue-distance">{{item.distance}}</text>
          </view>
        </view>
        <view class="venue-tags-row">
          <text class="venue-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</text>
        </view>
        <view class="match-bar">
          <view class="match-track">
            <view class="match-fill" style="width: {{item.match}}%;"></view>
          </view>
          <text class="match-text">匹配度 {{item.match}}%</text>
        </view>
      </view>
      <view class="select-box">
        <view class="select-circle {{item.selected ? 'select-circle-active' : ''}}">
          <text wx:if="{{item.selected}}" class="select-check">✓</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="list-footer"></view>
  </scroll-view>

  <!-- 底部确认按钮 -->
  <view class="bottom-bar">
    <view class="confirm-btn" bindtap="confirmVote">
      <text class="confirm-text">确认候选并发起投票 ({{selectedCount}})</text>
    </view>
  </view>

  <!-- 智能重排悬浮按钮 -->
  <view class="fab-btn" bindtap="smartReorder">
    <text class="fab-icon">✨</text>
    <text class="fab-text">智能重排</text>
  </view>
</view>
