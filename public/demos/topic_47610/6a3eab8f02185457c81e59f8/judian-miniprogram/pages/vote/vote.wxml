<view class="vote-container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <image src="/images/icon-back.png" mode="aspectFit" class="back-icon" />
    </view>
    <text class="nav-title">投票结果</text>
  </view>

  <!-- 副标题 -->
  <view class="sub-header">
    <text class="sub-title">根据4人需求自动排序</text>
  </view>

  <!-- 最佳推荐卡片 -->
  <view class="best-card">
    <image class="best-image" src="{{bestItem.image}}" mode="aspectFill" />
    <view class="best-info">
      <text class="best-name">{{bestItem.name}}</text>
      <view class="best-tags">
        <text class="tag" wx:for="{{bestItem.tags}}" wx:key="index">{{item}}</text>
      </view>
      <view class="best-rating">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{bestItem.score}}%"></view>
        </view>
        <text class="vote-count">{{bestItem.votes}}票</text>
      </view>
    </view>
    <view class="best-badge">最佳推荐</view>
  </view>

  <!-- Top3 网格 -->
  <view class="top3-section">
    <view class="section-title">Top 3 推荐</view>
    <view class="grid-2">
      <view class="grid-item" wx:for="{{topList}}" wx:key="id">
        <image class="grid-image" src="{{item.image}}" mode="aspectFill" />
        <view class="grid-info">
          <text class="grid-name">{{item.name}}</text>
          <text class="grid-distance">{{item.distance}}</text>
          <view class="grid-tags">
            <text class="grid-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</text>
          </view>
          <view class="grid-score-row">
            <view class="grid-progress">
              <view class="grid-progress-fill" style="width: {{item.score}}%"></view>
            </view>
            <text class="grid-score">{{item.score}}分</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn-route" bindtap="viewRoute">查看路线</button>
    <button class="btn-rematch" bindtap="rematch">重新匹配</button>
  </view>
</view>
