page {
  background-color: #f5f6fa;
}

.vote-container {
  padding: 0 32rpx 40rpx;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  padding-top: 88rpx;
  padding-bottom: 20rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-left: 16rpx;
}

/* 副标题 */
.sub-header {
  margin-bottom: 24rpx;
}

.sub-title {
  font-size: 26rpx;
  color: #888;
}

/* 最佳推荐卡片 */
.best-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.best-image {
  width: 100%;
  height: 360rpx;
}

.best-info {
  padding: 24rpx;
}

.best-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.best-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #ff6b6b;
  background: rgba(255,107,107,0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.best-rating {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b6b, #ff8e53);
  border-radius: 8rpx;
}

.vote-count {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.best-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e53);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: bold;
}

/* Top3 网格 */
.top3-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.grid-2 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-item {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.grid-image {
  width: 100%;
  height: 200rpx;
}

.grid-info {
  padding: 16rpx;
}

.grid-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.grid-distance {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.grid-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.grid-tag {
  font-size: 20rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.grid-score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.grid-progress {
  flex: 1;
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.grid-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  border-radius: 6rpx;
}

.grid-score {
  font-size: 22rpx;
  color: #4facfe;
  font-weight: bold;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
}

.btn-route,
.btn-rematch {
  width: 46%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.btn-route {
  background: #1a1a1a;
  color: #fff;
}

.btn-rematch {
  background: #fff;
  color: #1a1a1a;
  border: 2rpx solid #ddd;
}
