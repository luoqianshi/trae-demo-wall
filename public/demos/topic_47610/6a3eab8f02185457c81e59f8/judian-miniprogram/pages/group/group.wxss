page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 状态栏 */
.status-bar {
  background-color: #ffffff;
}

/* 页面标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 30rpx;
  background-color: #ffffff;
}

.header-left {
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.title-area {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.page-subtitle {
  font-size: 24rpx;
  color: #888888;
  margin-top: 6rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qr-code {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
}

.member-avatars {
  display: flex;
  align-items: center;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  margin-left: -16rpx;
}

.avatar:first-child {
  margin-left: 0;
}

/* 地图区域 */
.map-section {
  padding: 30rpx;
}

.map-container {
  position: relative;
  width: 100%;
  height: 560rpx;
  background-color: #1a1a2e;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 同心圆 */
.circle {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  animation: pulse 3s ease-in-out infinite;
}

.circle-2 {
  width: 340rpx;
  height: 340rpx;
  animation: pulse 3s ease-in-out infinite 0.5s;
}

.circle-3 {
  width: 480rpx;
  height: 480rpx;
  animation: pulse 3s ease-in-out infinite 1s;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

.center-dot {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background-color: #ff6b6b;
  border-radius: 50%;
  box-shadow: 0 0 20rpx rgba(255, 107, 107, 0.6);
}

/* 成员位置点 */
.member-dot {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  overflow: hidden;
}

.dot-avatar {
  width: 100%;
  height: 100%;
}

.dot-1 {
  top: 100rpx;
  left: 80rpx;
}

.dot-2 {
  top: 120rpx;
  right: 100rpx;
}

.dot-3 {
  bottom: 140rpx;
  left: 120rpx;
}

.dot-4 {
  bottom: 100rpx;
  right: 80rpx;
}

/* 玻璃卡片 */
.glass-card {
  margin: 0 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  background-color: rgba(245, 246, 250, 0.8);
  border-radius: 16rpx;
}

.info-label {
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 40rpx 30rpx;
  margin-top: auto;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-secondary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 8rpx 24rpx rgba(245, 87, 108, 0.4);
}

.btn-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
