<view class="container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 页面标题栏 -->
  <view class="header">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">&#60;</text>
      </view>
      <view class="title-area">
        <text class="page-title">周末干饭小组</text>
        <text class="page-subtitle">4人组队 · 正在等待需求确认</text>
      </view>
    </view>
    <view class="header-right">
      <image class="qr-code" src="https://images.unsplash.com/photo-1599658880436-c61792e70672?w=120&h=120&fit=crop" mode="aspectFill" bindtap="showQRCode"></image>
      <view class="member-avatars">
        <image class="avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100&h=100&fit=crop&crop=face" mode="aspectFill"></image>
        <image class="avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" mode="aspectFill"></image>
        <image class="avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" mode="aspectFill"></image>
        <image class="avatar avatar-more" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=face" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- 地图区域 -->
  <view class="map-section">
    <view class="map-container">
      <!-- 同心圆 -->
      <view class="circle circle-1"></view>
      <view class="circle circle-2"></view>
      <view class="circle circle-3"></view>
      <view class="center-dot"></view>
      <!-- 成员位置点 -->
      <view class="member-dot dot-1">
        <image class="dot-avatar" src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=80&h=80&fit=crop&crop=face" mode="aspectFill"></image>
      </view>
      <view class="member-dot dot-2">
        <image class="dot-avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" mode="aspectFill"></image>
      </view>
      <view class="member-dot dot-3">
        <image class="dot-avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" mode="aspectFill"></image>
      </view>
      <view class="member-dot dot-4">
        <image class="dot-avatar" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&h=80&fit=crop&crop=face" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- 需求状态玻璃卡片 -->
  <view class="glass-card">
    <view class="card-title">当前需求状态</view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">人均预算</text>
        <text class="info-value">150元</text>
      </view>
      <view class="info-item">
        <text class="info-label">氛围</text>
        <text class="info-value">轻松休闲</text>
      </view>
      <view class="info-item">
        <text class="info-label">交通</text>
        <text class="info-value">地铁直达</text>
      </view>
      <view class="info-item">
        <text class="info-label">时间</text>
        <text class="info-value">周六晚7点</text>
      </view>
      <view class="info-item">
        <text class="info-label">口味</text>
        <text class="info-value">火锅/烧烤</text>
      </view>
      <view class="info-item">
        <text class="info-label">特殊需求</text>
        <text class="info-value">无</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <view class="btn btn-primary" bindtap="goToFillNeed">
      <text class="btn-text">填写我的需求</text>
    </view>
    <view class="btn btn-secondary" bindtap="goToCandidates">
      <text class="btn-text">查看候选地</text>
    </view>
  </view>
</view>
