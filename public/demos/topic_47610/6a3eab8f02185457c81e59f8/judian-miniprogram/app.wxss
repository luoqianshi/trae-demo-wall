@import "./styles/variables.wxss";

page {
  background: var(--bg-deep);
  color: var(--text-primary);
  font-family: 'PingFang SC', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
  min-height: 100vh;
}

/* Status bar placeholder */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 20px 8px;
  font-size: 14px;
  font-weight: 600;
}

/* Glass Card */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border);
  border-radius: 20px;
  position: relative;
  overflow: hidden;
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
}

/* Gradient Button */
.btn-gradient {
  background: var(--gradient-primary);
  border: none;
  border-radius: 30px;
  color: white;
  font-size: 16px;
  font-weight: 600;
  padding: 14px 32px;
  width: 100%;
  display: block;
  text-align: center;
  transition: transform 0.2s;
}

.btn-gradient:active {
  transform: scale(0.98);
}

.btn-gradient-outline {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 30px;
  color: white;
  font-size: 16px;
  font-weight: 600;
  padding: 14px 32px;
  width: 100%;
  display: block;
  text-align: center;
}

/* Input Field */
.input-field {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 14px 18px;
  color: white;
  font-size: 15px;
  width: 100%;
  outline: none;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: var(--text-muted);
}

.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.input-wrap .input-field {
  padding-left: 46px;
}

.input-icon {
  position: absolute;
  left: 16px;
  color: var(--text-muted);
  font-size: 18px;
  z-index: 1;
}

/* Page Header */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 20px 16px;
}

.page-header .back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.page-header .page-title h1 {
  font-size: 18px;
  font-weight: 600;
}

.page-header .right-actions {
  display: flex;
  gap: 12px;
}

/* Safe area bottom for pages without tabBar */
.page-content {
  padding: 0 20px calc(110px + env(safe-area-inset-bottom));
}

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-in {
  animation: fadeInUp 0.5s ease forwards;
}

.animate-delay-1 { animation-delay: 0.1s; }
.animate-delay-2 { animation-delay: 0.2s; }
.animate-delay-3 { animation-delay: 0.3s; }

/* Utility */
.text-center { text-align: center; }
.mt-20 { margin-top: 20px; }
.mb-16 { margin-bottom: 16px; }
