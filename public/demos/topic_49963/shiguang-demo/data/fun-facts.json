  { "id": "f-0131", "type": "funfact", "category": "宇宙天文", "text": "北极星并不在正北方向，但非常接近。", "source": "" },
  { "id": "f-0132", "type": "funfact", "category": "宇宙天文", "text": "银河系与仙女座星系约在四十五亿年后相撞。", "source": "" },
  { "id": "f-0133", "type": "funfact", "category": "宇宙天文", "text": "太阳每秒消耗约六百万吨氢。", "source": "" },
  { "id": "f-0134", "type": "funfact", "category": "宇宙天文", "text": "海王星上的风速可达每小时两千公里。", "source": "" },
  { "id": "f-0135", "type": "funfact", "category": "宇宙天文", "text": "宇宙中约百分之九十五的物质是暗物质和暗能量。", "source": "" },
  { "id": "f-0136", "type": "funfact", "category": "宇宙天文", "text": "国际空间站约每九十分钟绕地球一圈。", "source": "" },
  { "id": "f-0137", "type": "funfact", "category": "宇宙天文", "text": "火星上的奥林帕斯山是太阳系最高的山，约二十一公里。", "source": "" },
  { "id": "f-0138", "type": "funfact", "category": "宇宙天文", "text": "金星上的一天比一年还长。", "source": "" },
  { "id": "f-0139", "type": "funfact", "category": "宇宙天文", "text": "哈勃太空望远镜于1990年发射升空。", "source": "" },
  { "id": "f-0140", "type": "funfact", "category": "宇宙天文", "text": "银河系中心存在一个超大质量黑洞。", "source": "" }
]
