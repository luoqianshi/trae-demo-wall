[
  { "id": "q-0001", "type": "quote", "category": "治愈", "text": "生活不是等待暴风雨过去，而是学会在雨中跳舞。", "source": "未知" },
  { "id": "q-0002", "type": "quote", "category": "治愈", "text": "愿你成为自己的太阳，无需凭借谁的光。", "source": "《人民日报》" },
  { "id": "q-0003", "type": "quote", "category": "治愈", "text": "一切都会过去的，而过去了的，就会变成亲切的怀恋。", "source": "普希金《假如生活欺骗了你》" },
  { "id": "q-0004", "type": "quote", "category": "治愈", "text": "万物皆有裂痕，那是光照进来的地方。", "source": "莱昂纳德·科恩《Anthem》" },
  { "id": "q-0005", "type": "quote", "category": "治愈", "text": "慢慢来，比较快。", "source": "佚名" },
  { "id": "q-0006", "type": "quote", "category": "治愈", "text": "愿你被这世界温柔以待。", "source": "佚名" },
  { "id": "q-0007", "type": "quote", "category": "治愈", "text": "心若向阳，无谓悲伤。", "source": "佚名" },
  { "id": "q-0008", "type": "quote", "category": "治愈", "text": "三餐四季，温暖平凡。", "source": "佚名" },
  { "id": "q-0009", "type": "quote", "category": "治愈", "text": "你所走过的每一步，都不会白费。", "source": "佚名" },
  { "id": "q-0010", "type": "quote", "category": "治愈", "text": "那些偷偷溜走的时光，催老了我们的容颜，却丰盈了我们的人生。", "source": "佚名" },
  { "id": "q-0011", "type": "quote", "category": "治愈", "text": "山有顶峰，湖有彼岸，在人生漫漫长途中，万物皆有回转。", "source": "佚名" },
  { "id": "q-0012", "type": "quote", "category": "治愈", "text": "愿你眼里有光，心中有爱，一生被爱。", "source": "佚名" },
  { "id": "q-0013", "type": "quote", "category": "治愈", "text": "余生很贵，请别浪费。", "source": "佚名" },
  { "id": "q-0014", "type": "quote", "category": "治愈", "text": "别担心，你是被爱的人。", "source": "佚名" },
  { "id": "q-0015", "type": "quote", "category": "治愈", "text": "你今天的努力，是幸运的伏笔。", "source": "佚名" },
  { "id": "q-0016", "type": "quote", "category": "治愈", "text": "愿有人陪你颠沛流离，如果没有，愿你成为自己的太阳。", "source": "佚名" },
  { "id": "q-0017", "type": "quote", "category": "治愈", "text": "时间会告诉我们，简单的喜欢最长远，平凡中的陪伴最心安。", "source": "佚名" },
  { "id": "q-0018", "type": "quote", "category": "治愈", "text": "你不必光芒万丈，也不必有什么特殊意义，你只需做那个小小的你，然后用心去爱。", "source": "佚名" },
  { "id": "q-0019", "type": "quote", "category": "治愈", "text": "去爱吧，就像不曾受过一次伤一样。", "source": "佚名" },
  { "id": "q-0020", "type": "quote", "category": "治愈", "text": "当你觉得整个世界都背弃了你，其实只是世界在为你腾出空间，去迎接更好的人。", "source": "佚名" },
  { "id": "q-0021", "type": "quote", "category": "励志", "text": "每一个不曾起舞的日子，都是对生命的辜负。", "source": "尼采" },
  { "id": "q-0022", "type": "quote", "category": "励志", "text": "天行健，君子以自强不息。", "source": "《周易》" },
  { "id": "q-0023", "type": "quote", "category": "励志", "text": "千里之行，始于足下。", "source": "《老子》" },
  { "id": "q-0024", "type": "quote", "category": "励志", "text": "宝剑锋从磨砺出，梅花香自苦寒来。", "source": "《警世贤文》" },
  { "id": "q-0025", "type": "quote", "category": "励志", "text": "锲而不舍，金石可镂。", "source": "《荀子·劝学》" },
  { "id": "q-0026", "type": "quote", "category": "励志", "text": "不积跬步，无以至千里；不积小流，无以成江海。", "source": "《荀子·劝学》" },
  { "id": "q-0027", "type": "quote", "category": "励志", "text": "业精于勤，荒于嬉；行成于思，毁于随。", "source": "韩愈《进学解》" },
  { "id": "q-0028", "type": "quote", "category": "励志", "text": "世上无难事，只要肯登攀。", "source": "毛泽东《水调歌头·重上井冈山》" },
  { "id": "q-0029", "type": "quote", "category": "励志", "text": "一寸光阴一寸金，寸金难买寸光阴。", "source": "《增广贤文》" },
  { "id": "q-0030", "type": "quote", "category": "励志", "text": "黑发不知勤学早，白首方悔读书迟。", "source": "颜真卿《劝学诗》" },
  { "id": "q-0031", "type": "quote", "category": "励志", "text": "种一棵树最好的时间是十年前，其次是现在。", "source": "谚语" },
  { "id": "q-0032", "type": "quote", "category": "励志", "text": "你现在的付出，都会是一种沉淀，它们会默默铺路，只为让你成为更好的人。", "source": "佚名" },
  { "id": "q-0033", "type": "quote", "category": "励志", "text": "哪怕是最没有希望的事情，只要坚持去做，到最后就会拥有希望。", "source": "佚名" },
  { "id": "q-0034", "type": "quote", "category": "励志", "text": "当你停下来休息的时候，别忘了别人还在奔跑。", "source": "佚名" },
  { "id": "q-0035", "type": "quote", "category": "励志", "text": "没有伞的孩子必须努力奔跑。", "source": "佚名" },
  { "id": "q-0036", "type": "quote", "category": "励志", "text": "你只管努力，剩下的交给时间。", "source": "佚名" },
  { "id": "q-0037", "type": "quote", "category": "励志", "text": "越努力，越幸运。", "source": "佚名" },
  { "id": "q-0038", "type": "quote", "category": "励志", "text": "不为模糊不清的未来担忧，只为清清楚楚的现在努力。", "source": "佚名" },
  { "id": "q-0039", "type": "quote", "category": "励志", "text": "所有的幸运，都是努力的伏笔。", "source": "佚名" },
  { "id": "q-0040", "type": "quote", "category": "励志", "text": "星光不问赶路人，时光不负有心人。", "source": "佚名" },
  { "id": "q-0041", "type": "quote", "category": "生活感悟", "text": "生活不止眼前的苟且，还有诗和远方的田野。", "source": "高晓松" },
  { "id": "q-0042", "type": "quote", "category": "生活感悟", "text": "人生没有彩排，每天都是现场直播。", "source": "佚名" },
  { "id": "q-0043", "type": "quote", "category": "生活感悟", "text": "你永远不知道，明天和意外哪个先来。", "source": "佚名" },
  { "id": "q-0044", "type": "quote", "category": "生活感悟", "text": "有些事，错过了就是一辈子；有些人，一转身就是一世。", "source": "佚名" },
  { "id": "q-0045", "type": "quote", "category": "生活感悟", "text": "简单的事重复做，你就是专家；重复的事用心做，你就是赢家。", "source": "佚名" },
  { "id": "q-0046", "type": "quote", "category": "生活感悟", "text": "人生就像一杯茶，不会苦一辈子，但总会苦一阵子。", "source": "佚名" },
  { "id": "q-0047", "type": "quote", "category": "生活感悟", "text": "与其埋怨世界，不如改变自己。", "source": "佚名" },
  { "id": "q-0048", "type": "quote", "category": "生活感悟", "text": "学会放下，是成长的开始。", "source": "佚名" },
  { "id": "q-0049", "type": "quote", "category": "生活感悟", "text": "不乱于心，不困于情，不畏将来，不念过往，如此，安好。", "source": "丰子恺《不宠无惊过一生》" },
  { "id": "q-0050", "type": "quote", "category": "生活感悟", "text": "心简单，世界就简单，幸福才会生长。", "source": "佚名" },
  { "id": "q-0051", "type": "quote", "category": "生活感悟", "text": "人生没有白走的路，每一步都算数。", "source": "李宗盛" },
  { "id": "q-0052", "type": "quote", "category": "生活感悟", "text": "你若盛开，蝴蝶自来；你若精彩，天自安排。", "source": "佚名" },
  { "id": "q-0053", "type": "quote", "category": "生活感悟", "text": "成熟不是心变老，而是眼泪在眼眶里打转却还能微笑。", "source": "佚名" },
  { "id": "q-0054", "type": "quote", "category": "生活感悟", "text": "时间会冲淡一切，也会沉淀一切。", "source": "佚名" },
  { "id": "q-0055", "type": "quote", "category": "生活感悟", "text": "懂得知足，才能常乐。", "source": "佚名" },
  { "id": "q-0056", "type": "quote", "category": "生活感悟", "text": "生活最大的危险在于一个空虚的心灵。", "source": "佚名" },
  { "id": "q-0057", "type": "quote", "category": "生活感悟", "text": "与其讨好别人，不如武装自己；与其逃避现实，不如笑对人生。", "source": "佚名" },
  { "id": "q-0058", "type": "quote", "category": "生活感悟", "text": "没有过不去的事情，只有过不去的心情。", "source": "佚名" },
  { "id": "q-0059", "type": "quote", "category": "文学摘录", "text": "世界以痛吻我，要我报之以歌。", "source": "泰戈尔《飞鸟集》" },
  { "id": "q-0060", "type": "quote", "category": "文学摘录", "text": "生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。", "source": "海明威《永别了，武器》" },
  { "id": "q-0061", "type": "quote", "category": "文学摘录", "text": "人是为活着本身而活着，而不是为了活着之外的任何事物所活着。", "source": "余华《活着》" },
  { "id": "q-0062", "type": "quote", "category": "文学摘录", "text": "幸福的家庭都是相似的，不幸的家庭各有各的不幸。", "source": "列夫·托尔斯泰《安娜·卡列尼娜》" },
  { "id": "q-0063", "type": "quote", "category": "文学摘录", "text": "这是最好的时代，这是最坏的时代。", "source": "狄更斯《双城记》" },
  { "id": "q-0064", "type": "quote", "category": "文学摘录", "text": "一个人并不是生来要给打败的，你尽可以把他消灭掉，可就是打不败他。", "source": "海明威《老人与海》" },
  { "id": "q-0065", "type": "quote", "category": "文学摘录", "text": "所谓父女母子一场，只不过意味着，你和他的缘分就是今生今世不断地在目送他的背影渐行渐远。", "source": "龙应台《目送》" },
  { "id": "q-0066", "type": "quote", "category": "文学摘录", "text": "于千万人之中遇见你所要遇见的人，于千万年之中，时间的无涯的荒野里，没有早一步，也没有晚一步，刚巧赶上了。", "source": "张爱玲《爱》" },
  { "id": "q-0067", "type": "quote", "category": "文学摘录", "text": "我看到那些岁月如何奔驰，挨过了冬季，便迎来了春天。", "source": "梭罗《瓦尔登湖》" },
  { "id": "q-0068", "type": "quote", "category": "文学摘录", "text": "世界上只有一种真正的英雄主义，那就是在认清生活真相之后依然热爱生活。", "source": "罗曼·罗兰《米开朗琪罗传》" },
  { "id": "q-0069", "type": "quote", "category": "文学摘录", "text": "你站在桥上看风景，看风景人在楼上看你。明月装饰了你的窗子，你装饰了别人的梦。", "source": "卞之琳《断章》" },
  { "id": "q-0070", "type": "quote", "category": "文学摘录", "text": "从前的日色变得慢，车，马，邮件都慢，一生只够爱一个人。", "source": "木心《从前慢》" },
  { "id": "q-0071", "type": "quote", "category": "文学摘录", "text": "面朝大海，春暖花开。", "source": "海子《面朝大海，春暖花开》" },
  { "id": "q-0072", "type": "quote", "category": "文学摘录", "text": "卑鄙是卑鄙者的通行证，高尚是高尚者的墓志铭。", "source": "北岛《回答》" },
  { "id": "q-0073", "type": "quote", "category": "文学摘录", "text": "黑夜给了我黑色的眼睛，我却用它寻找光明。", "source": "顾城《一代人》" },
  { "id": "q-0074", "type": "quote", "category": "文学摘录", "text": "为什么我的眼里常含泪水？因为我对这土地爱得深沉。", "source": "艾青《我爱这土地》" },
  { "id": "q-0075", "type": "quote", "category": "文学摘录", "text": "生活不可能像你想象得那么好，但也不会像你想象得那么糟。", "source": "莫泊桑《一生》" },
  { "id": "q-0076", "type": "quote", "category": "文学摘录", "text": "也许每一个男子全都有过这样的两个女人，至少两个。", "source": "张爱玲《红玫瑰与白玫瑰》" },
  { "id": "q-0077", "type": "quote", "category": "电影台词", "text": "希望是美好的，也许是人间至善，而美好的事物永不消逝。", "source": "《肖申克的救赎》" },
  { "id": "q-0078", "type": "quote", "category": "电影台词", "text": "生活就像一盒巧克力，你永远不知道下一颗是什么味道。", "source": "《阿甘正传》" },
  { "id": "q-0079", "type": "quote", "category": "电影台词", "text": "不管前方的路有多苦，只要走的方向正确，不管多么崎岖，都比站在原地更接近幸福。", "source": "《千与千寻》" },
  { "id": "q-0080", "type": "quote", "category": "电影台词", "text": "人生就是不断地放下，但最遗憾的是我们来不及好好告别。", "source": "《少年派的奇幻漂流》" },
  { "id": "q-0081", "type": "quote", "category": "电影台词", "text": "如果你有梦想，就要去捍卫它。那些自己做不到的人，会告诉你你也做不到。", "source": "《当幸福来敲门》" },
  { "id": "q-0082", "type": "quote", "category": "电影台词", "text": "做人如果没有梦想，跟咸鱼有什么分别？", "source": "《少林足球》" },
  { "id": "q-0083", "type": "quote", "category": "电影台词", "text": "曾经有一份真诚的爱情放在我面前，我没有珍惜，等我失去的时候我才后悔莫及。", "source": "《大话西游》" },
  { "id": "q-0084", "type": "quote", "category": "电影台词", "text": "我猜中了前头，可是我猜不着这结局。", "source": "《大话西游》" },
  { "id": "q-0085", "type": "quote", "category": "电影台词", "text": "如果多一张船票，你愿不愿意跟我一起走？", "source": "《花样年华》" },
  { "id": "q-0086", "type": "quote", "category": "电影台词", "text": "世界上只有一种病，穷病。", "source": "《我不是药神》" },
  { "id": "q-0087", "type": "quote", "category": "电影台词", "text": "我命由我不由天，是魔是仙，我自己说了算。", "source": "《哪吒之魔童降世》" },
  { "id": "q-0088", "type": "quote", "category": "电影台词", "text": "我们一路奋战，不是为了改变世界，而是为了不让世界改变我们。", "source": "《熔炉》" },
  { "id": "q-0089", "type": "quote", "category": "电影台词", "text": "你保护世界，我保护你。", "source": "《少年的你》" },
  { "id": "q-0090", "type": "quote", "category": "电影台词", "text": "愿原力与你同在。", "source": "《星球大战》" },
  { "id": "q-0091", "type": "quote", "category": "电影台词", "text": "我会回来的。", "source": "《终结者》" },
  { "id": "q-0092", "type": "quote", "category": "电影台词", "text": "你跳，我也跳。", "source": "《泰坦尼克号》" },
  { "id": "q-0093", "type": "quote", "category": "电影台词", "text": "飞向宇宙，浩瀚无垠！", "source": "《玩具总动员》" },
  { "id": "q-0094", "type": "quote", "category": "电影台词", "text": "世界上有那么多的城镇，城镇中有那么多的酒馆，她却走进了我的。", "source": "《卡萨布兰卡》" },
  { "id": "q-0095", "type": "quote", "category": "电影台词", "text": "永远不要恨你的敌人，那会影响你的判断力。", "source": "《教父》" },
  { "id": "q-0096", "type": "quote", "category": "电影台词", "text": "给你一个无法拒绝的条件。", "source": "《教父》" },
  { "id": "q-0097", "type": "quote", "category": "古诗词", "text": "山重水复疑无路，柳暗花明又一村。", "source": "陆游《游山西村》" },
  { "id": "q-0098", "type": "quote", "category": "古诗词", "text": "长风破浪会有时，直挂云帆济沧海。", "source": "李白《行路难》" },
  { "id": "q-0099", "type": "quote", "category": "古诗词", "text": "会当凌绝顶，一览众山小。", "source": "杜甫《望岳》" },
  { "id": "q-0100", "type": "quote", "category": "古诗词", "text": "海内存知己，天涯若比邻。", "source": "王勃《送杜少府之任蜀州》" },
  { "id": "q-0101", "type": "quote", "category": "古诗词", "text": "莫愁前路无知己，天下谁人不识君。", "source": "高适《别董大》" },
  { "id": "q-0102", "type": "quote", "category": "古诗词", "text": "落霞与孤鹜齐飞，秋水共长天一色。", "source": "王勃《滕王阁序》" },
  { "id": "q-0103", "type": "quote", "category": "古诗词", "text": "但愿人长久，千里共婵娟。", "source": "苏轼《水调歌头》" },
  { "id": "q-0104", "type": "quote", "category": "古诗词", "text": "人有悲欢离合，月有阴晴圆缺，此事古难全。", "source": "苏轼《水调歌头》" },
  { "id": "q-0105", "type": "quote", "category": "古诗词", "text": "不识庐山真面目，只缘身在此山中。", "source": "苏轼《题西林壁》" },
  { "id": "q-0106", "type": "quote", "category": "古诗词", "text": "竹外桃花三两枝，春江水暖鸭先知。", "source": "苏轼《惠崇春江晚景》" },
  { "id": "q-0107", "type": "quote", "category": "古诗词", "text": "采菊东篱下，悠然见南山。", "source": "陶渊明《饮酒》" },
  { "id": "q-0108", "type": "quote", "category": "古诗词", "text": "海上生明月，天涯共此时。", "source": "张九龄《望月怀远》" },
  { "id": "q-0109", "type": "quote", "category": "古诗词", "text": "两个黄鹂鸣翠柳，一行白鹭上青天。", "source": "杜甫《绝句》" },
  { "id": "q-0110", "type": "quote", "category": "古诗词", "text": "随风潜入夜，润物细无声。", "source": "杜甫《春夜喜雨》" },
  { "id": "q-0111", "type": "quote", "category": "古诗词", "text": "春风又绿江南岸，明月何时照我还。", "source": "王安石《泊船瓜洲》" },
  { "id": "q-0112", "type": "quote", "category": "古诗词", "text": "接天莲叶无穷碧，映日荷花别样红。", "source": "杨万里《晓出净慈寺送林子方》" },
  { "id": "q-0113", "type": "quote", "category": "古诗词", "text": "忽如一夜春风来，千树万树梨花开。", "source": "岑参《白雪歌送武判官归京》" },
  { "id": "q-0114", "type": "quote", "category": "古诗词", "text": "我寄愁心与明月，随君直到夜郎西。", "source": "李白《闻王昌龄左迁龙标遥有此寄》" },
  { "id": "q-0115", "type": "quote", "category": "古诗词", "text": "桃花潭水深千尺，不及汪伦送我情。", "source": "李白《赠汪伦》" },
  { "id": "q-0116", "type": "quote", "category": "古诗词", "text": "谁言寸草心，报得三春晖。", "source": "孟郊《游子吟》" }
]
