{
  "name": "yanyiji-desktop",
  "version": "0.1.0",
  "description": "研易记 - 基于大模型的论文公式提取桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron ."
  },
  "keywords": ["electron", "latex", "ocr", "formula", "yanyiji"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^32.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "build": {
    "appId": "com.yanyiji.desktop",
    "productName": "研易记",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "deb"
    }
  }
}