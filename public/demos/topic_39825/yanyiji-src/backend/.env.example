# 研易记 环境变量配置
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=研易记 API
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/yanyiji

# Redis
REDIS_URL=redis://localhost:6379/0
4
# ============================================================
# VLM 多模态模型配置（核心）
# 支持任何 OpenAI 兼容接口的供应商，任选其一即可
# ============================================================

# --- 方式一：OpenAI 官方 ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# VLM_MODEL=gpt-4o

# --- 方式二：DeepSeek（国内推荐，便宜好用）---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# VLM_MODEL=deepseek-chat

# --- 方式三：阿里云百炼（Qwen-VL）---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLM_MODEL=qwen-vl-max

# --- 方式四：智谱 GLM-4V ---
# OPENAI_API_KEY=xxx
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VLM_MODEL=glm-4v

# --- 方式五：其他 OpenAI 兼容 API（如中转站）---
# 注意：中转站需确认支持 /chat/completions 接口
# 且模型名需与中转站提供的一致
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://your-api-proxy.com/v1
# VLM_MODEL=claude-3-5-sonnet




# 图像处理
MAX_IMAGE_SIZE=4096
IMAGE_QUALITY=85

# 安全
SECRET_KEY=change-this-to-a-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 配额
FREE_USER_DAILY_QUOTA=50