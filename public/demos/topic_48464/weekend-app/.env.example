# 周末灵感生成器 - 环境变量配置示例
# 复制为 .env 并填入实际值

# 服务端口
PORT=3000

# 管理令牌（保护配置/缓存/指标等管理端点，不设则公开访问）
# ADMIN_TOKEN=your-secret-admin-token

# 大模型配置（可选，不填则使用规则引擎）
# LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_MS=60000

# 离线演示模式（强制使用规则引擎，跳过外部 API，适合无网络环境演示）
# DEMO_OFFLINE=true
