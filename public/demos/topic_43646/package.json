{
  "name": "chuannan-travel",
  "version": "1.0.0",
  "description": "川南旅行规划助手",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "exe": "pkg server.js --targets node18-win-x64 --output dist/川南旅行规划助手.exe"
  },
  "keywords": [
    "travel",
    "sichuan",
    "itinerary"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "iconv-lite": "^0.7.2"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "pkg": "^5.8.1"
  },
  "build": {
    "appId": "com.chuannan.travel",
    "productName": "川南旅行规划助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "川南旅行规划助手.exe"
    }
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
