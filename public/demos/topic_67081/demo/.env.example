# ====================================================================
#   易愈（YìYù）— API 配置模板
# ====================================================================
# 复制本文件为 .env 并填入真实 Key（.env 不进 git，不外传）
# 下方两套方案二选一即可，推荐 DeepSeek（注册即送余额，便宜稳定）
# 变量名虽为 ARK_*，但兼容任何 OpenAI 兼容协议的 Provider
# ARK_API_KEY 留空或无效 → 自动降级为规则模式（无 LLM 对话）
# ====================================================================

# ---------- 方案 A：DeepSeek（推荐）----------
# 注册地址：https://platform.deepseek.com/
ARK_API_KEY=your_deepseek_api_key_here
ARK_MODEL=deepseek-v4-pro
ARK_BASE_URL=https://api.deepseek.com

# ---------- 方案 B：火山引擎方舟 ----------
# 注册地址：https://console.volcengine.com/ark
# 如需切换：注释掉上方方案 A 三行，取消下方三行注释并填入 Key
# ARK_API_KEY=your_volcengine_api_key_here
# ARK_MODEL=doubao-1.5-pro-32k
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
