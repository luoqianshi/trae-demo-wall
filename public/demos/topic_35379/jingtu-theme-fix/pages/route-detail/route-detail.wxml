<!-- pages/route-detail/route-detail.wxml —— 路线详情 -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <block wx:if="{{route}}">
    <view class="detail-head">
      <view class="detail-name">{{route.name}}</view>
      <view class="detail-meta">{{route.distanceKm}}km · 约 {{route.durationMin}} 分钟</view>
      <view class="detail-meta detail-meta-sub">适合：{{route.sportsText}} / {{route.timeSlotsText}}</view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>路线示意图</view>
      <view class="mock-map">
        <view
          wx:for="{{route.polylineMock}}"
          wx:for-item="node"
          wx:key="label"
          class="map-node">
          <view class="map-dot {{index === 0 ? 'start' : (index === route.polylineMock.length - 1 ? 'end' : '')}}">{{index + 1}}</view>
          <view class="map-label">
            <view class="map-label-text">{{node.label}}</view>
          </view>
        </view>
      </view>
      <view class="text-muted text-small">（仅为简化示意，真实使用时可替换为地图 SDK）</view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>道路属性</view>
      <view class="tag-row">
        <view
          wx:for="{{route.surfaceTypes}}"
          wx:for-item="s"
          wx:key="*this"
          class="tag tag-info">{{s}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>四维评分</view>
      <view
        wx:for="{{dimScores}}"
        wx:for-item="dim"
        wx:key="key"
        class="score-row">
        <view class="score-label">{{dim.label}}</view>
        <view class="score-bar">
          <view class="score-bar-inner" style="width:{{dim.value}}%;"></view>
        </view>
        <view class="score-value">{{dim.value}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>路线统计</view>
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-icon">🌙</view>
          <view class="stat-value">{{stats.quietMinutes}}<text class="stat-unit">分钟</text></view>
          <view class="stat-label">预计安静时长</view>
        </view>
        <view class="stat-item">
          <view class="stat-icon">🌿</view>
          <view class="stat-value">{{stats.greenRate}}<text class="stat-unit">%</text></view>
          <view class="stat-label">绿化占比</view>
        </view>
        <view class="stat-item">
          <view class="stat-icon">🚶</view>
          <view class="stat-value">{{stats.avgSpeed}}<text class="stat-unit">km/h</text></view>
          <view class="stat-label">舒适时速</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>路况反馈</view>
      <view wx:if="{{route.tags.length > 0}}" class="tag-row">
        <view
          wx:for="{{route.tags}}"
          wx:for-item="t"
          wx:key="*this"
          class="tag tag-pos">{{t}}</view>
      </view>
      <view wx:if="{{route.riskReports.length > 0}}" class="tag-row">
        <view
          wx:for="{{route.riskReports}}"
          wx:for-item="r"
          wx:key="*this"
          class="tag tag-warn">⚠ {{r}}</view>
      </view>
      <view wx:if="{{route.tags.length === 0 && route.riskReports.length === 0}}" class="text-muted text-small">
        暂无上报，欢迎你成为第一位反馈的用户。
      </view>
    </view>

    <!-- 随笔记录 -->
    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>📝 我的随笔</view>
      <textarea
        class="field-textarea"
        placeholder="记录这次散步/骑行的心情与感悟..."
        value="{{note}}"
        maxlength="300"
        bindinput="onNoteInput" />
      <view class="note-actions">
        <view class="btn-ghost btn-small" bindtap="saveNote">
          {{noteSaved ? '✓ 已保存' : '保存随笔'}}
        </view>
      </view>
    </view>

    <view class="card ai-reason-card">
      <view class="section-title"><view class="section-title-bar"></view>🤖 AI 推荐解释</view>
      <view class="ai-reason-text">{{route.reason}}</view>
      <view wx:if="{{route.riskReports.length > 0}}" class="ai-reason-text text-muted text-small" style="margin-top:16rpx;">
        结合近期全民反馈：{{route.riskReportsText}}，AI 在推荐中已适度降权。
      </view>
    </view>

    <view class="bottom-bar">
      <view class="btn-ghost" bindtap="onBack">返回推荐</view>
      <view class="action-btn-primary" bindtap="onGoReport">去评分上报</view>
    </view>
  </block>

  <view wx:else class="empty">路线未找到</view>
</view>
