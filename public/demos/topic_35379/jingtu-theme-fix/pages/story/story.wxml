<!-- pages/story/story.wxml —— 故事溯源页 -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <!-- 头部 -->
  <view class="story-header">
    <view class="story-title">📖 静途故事</view>
    <view class="story-subtitle">关于我们为什么存在</view>
  </view>

  <!-- 故事卡片列表 -->
  <view wx:for="{{stories}}" wx:key="title" class="card story-card">
    <view class="story-icon">{{item.icon}}</view>
    <view class="story-content">
      <view class="story-card-title">{{item.title}}</view>
      <view class="story-card-desc">{{item.desc}}</view>
      <view class="story-highlight">{{item.highlight}}</view>
    </view>
  </view>

  <!-- 图片上传区域 -->
  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>📸 我的慢行瞬间</view>
    
    <!-- 图片网格 -->
    <view wx:if="{{uploadedImages.length > 0}}" class="image-grid">
      <view
        wx:for="{{uploadedImages}}"
        wx:key="index"
        class="image-item"
        data-src="{{item}}"
        data-index="{{index}}"
        bindtap="onPreviewImage">
        <image src="{{item}}" mode="aspectFill" class="image-thumb" />
        <view class="image-delete" data-index="{{index}}" bindtap="onDeleteImage">×</view>
      </view>
    </view>

    <!-- 添加图片按钮 -->
    <view class="add-image-btn" bindtap="onChooseImage">
      <text class="add-icon">+</text>
      <text class="add-text">上传步道风景</text>
    </view>

    <view class="text-muted text-small" style="margin-top:16rpx;">
      💡 照片仅保存在你的设备中，不会上传到云端
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="story-footer">
    <view class="footer-btn" bindtap="onGoIndex">
      <text class="footer-icon">🏠</text>
      <text class="footer-text">返回首页</text>
    </view>
    <view class="footer-btn" bindtap="onBack">
      <text class="footer-icon">←</text>
      <text class="footer-text">返回上一页</text>
    </view>
  </view>
</view>