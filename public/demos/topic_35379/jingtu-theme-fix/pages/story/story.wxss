/* pages/story/story.wxss */

.story-header {
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #0F9D58 0%, #4285F4 100%);
}

.story-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.story-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.story-card {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.story-icon {
  font-size: 48rpx;
  line-height: 1;
  flex-shrink: 0;
}

.story-content {
  flex: 1;
}

.story-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C3A2C;
  margin-bottom: 12rpx;
}

.story-card-desc {
  font-size: 26rpx;
  color: #5A6B62;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.story-highlight {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #E6F7EC 0%, #E8F0FE 100%);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #0F9D58;
  font-weight: 600;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.image-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-image-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  border: 2rpx dashed #B8C4BE;
  border-radius: 20rpx;
  background: #FAFBFB;
}

.add-icon {
  font-size: 48rpx;
  color: #97A8A0;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: #97A8A0;
}

.story-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 60rpx;
}

.footer-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.footer-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #5A6B62;
}