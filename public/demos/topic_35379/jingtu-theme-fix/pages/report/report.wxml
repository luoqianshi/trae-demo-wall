<!-- pages/report/report.wxml —— 路况评分与上报（支持问题修复） -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <block wx:if="{{route}}">
    <view class="card report-head" style="background:var(--theme-gradient-primary);box-shadow:var(--theme-shadow);margin:28rpx 32rpx;">
      <view class="report-title">{{route.name}}</view>
      <view class="report-sub">{{route.distanceKm}}km · {{route.durationMin}}分钟</view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>给这条路线打分（1~5 星）</view>
      <view
        wx:for="{{starRows}}"
        wx:for-item="row"
        wx:key="key"
        class="star-line">
        <view class="star-label">{{row.label}}</view>
        <view class="stars">
          <view
            wx:for="{{row.stars}}"
            wx:for-item="s"
            wx:key="n"
            class="star {{s.on ? 'on' : ''}}"
            data-key="{{row.key}}"
            data-value="{{s.n}}"
            bindtap="onStar">
            {{s.on ? '★' : '☆'}}
          </view>
        </view>
        <view class="star-num">{{row.value * 20}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>一键上报路况隐患</view>
      <view class="option-row">
        <view
          wx:for="{{riskOptions}}"
          wx:key="value"
          class="option-item {{item.selected ? 'active-risk' : ''}}"
          data-value="{{item.value}}"
          bindtap="onToggleRisk">
          {{item.label}}
        </view>
      </view>
      <view class="text-muted text-small" style="margin-top:16rpx;">
        💡 小提示：隐患上报会降低路线得分，帮助其他用户避开风险。
      </view>
    </view>

    <!-- 问题修复区域 -->
    <view class="card">
      <view class="section-title" bindtap="onToggleRepairSection">
        <view class="section-title-bar"></view>
        标记问题已修复（全民共建）
        <text class="toggle-arrow">{{showRepairSection ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showRepairSection}}">
        <view wx:if="{{existingRisks.length > 0}}" class="option-row">
          <view
            wx:for="{{existingRisks}}"
            wx:key="value"
            class="option-item {{item.selected ? 'active-repair' : 'repair-item'}}"
            data-value="{{item.value}}"
            bindtap="onToggleRepair">
            ✓ {{item.label}}
          </view>
        </view>
        <view wx:else class="empty-text">
          暂无已上报的隐患，成为第一个发现问题的人吧！
        </view>
        <view class="text-muted text-small" style="margin-top:16rpx;">
          💚 当你发现某个问题已修复，可以标记它，路线得分将会恢复。
        </view>
      </view>
    </view>

    <view wx:if="{{showHint}}" class="hint-card" style="margin:0 32rpx 28rpx;">
      <view class="hint-title">⚠ 照明提示</view>
      <view class="hint-text">感谢你的反馈。AI 会立即降低这条路线在夜间的安全推荐分，并提醒其他用户注意。</view>
    </view>

    <view class="btn-primary" bindtap="onSubmit">提交反馈 · 共建美好路线</view>

    <view class="tip-text">你的反馈将与其他用户的上报一起，参与 AI 路线推荐的动态计算。</view>
  </block>

  <view wx:else class="empty">路线未找到</view>
</view>