<view class="custom-tab-bar">
  <view 
    class="tab-item {{currentPage === '/pages/index/index' ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-page="/pages/index/index"
  >
    <view class="tab-icon">🏠</view>
    <view class="tab-text">首页</view>
  </view>
  <view 
    class="tab-item {{currentPage === '/pages/temperature/temperature' ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-page="/pages/temperature/temperature"
  >
    <view class="tab-icon">🌡️</view>
    <view class="tab-text">体温</view>
  </view>
  <view 
    class="tab-item {{currentPage === '/pages/medicine/medicine' ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-page="/pages/medicine/medicine"
  >
    <view class="tab-icon">💊</view>
    <view class="tab-text">用药</view>
  </view>
  <view 
    class="tab-item {{currentPage === '/pages/water/water' ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-page="/pages/water/water"
  >
    <view class="tab-icon">💧</view>
    <view class="tab-text">喝水</view>
  </view>
  <view 
    class="tab-item {{currentPage === '/pages/profile/profile' ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-page="/pages/profile/profile"
  >
    <view class="tab-icon">👤</view>
    <view class="tab-text">我的</view>
  </view>
</view>