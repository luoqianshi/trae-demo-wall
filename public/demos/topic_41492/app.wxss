page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-primary {
  color: #4CAF50;
}

.text-secondary {
  color: #999999;
}

.text-success {
  color: #4CAF50;
}

.text-warning {
  color: #ff9800;
}

.text-danger {
  color: #f44336;
}

.fs-24 {
  font-size: 24rpx;
}

.fs-28 {
  font-size: 28rpx;
}

.fs-32 {
  font-size: 32rpx;
}

.fs-36 {
  font-size: 36rpx;
}

.fs-48 {
  font-size: 48rpx;
}

.fw-bold {
  font-weight: 600;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.px-20 {
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.py-20 {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.radius-16 {
  border-radius: 16rpx;
}

.radius-8 {
  border-radius: 8rpx;
}

.status-normal {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.status-sick {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 70vh;
}

.modal-content-long {
  width: 85%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 85vh;
}

.modal-content-top {
  width: 85%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 70vh;
  position: absolute;
  top: 150rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
}

.modal-footer button {
  flex: 1;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 100rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  color: #999999;
  box-sizing: border-box;
}