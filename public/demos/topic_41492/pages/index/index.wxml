<view class="container">
  <view class="main-content">
    <view class="status-switch" bindtap="toggleMode">
      <view class="switch-content">
        <view class="switch-icon {{healthStatus}}">{{healthStatus === 'sick' ? '🤒' : '😊'}}</view>
        <view class="switch-text">
          <view class="mode-label">{{healthStatus === 'sick' ? '生病模式' : '正常模式'}}</view>
          <view class="mode-desc">{{healthStatus === 'sick' ? '按时吃药，多休息' : '保持健康生活习惯'}}</view>
        </view>
        <view class="switch-toggle">
          <view class="toggle-track {{healthStatus}}">
            <view class="toggle-thumb {{healthStatus}}"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-title">今日数据</view>
    
    <view class="stats-grid" wx:if="{{healthStatus === 'normal'}}">
      <view class="stat-card" bindtap="goToPage" data-page="/pages/weight/weight">
        <view class="stat-icon weight-icon">⚖️</view>
        <view class="stat-info">
          <view class="stat-value">{{todayWeight || '--'}}kg</view>
          <view class="stat-label">体重</view>
        </view>
      </view>
      <view class="stat-card" bindtap="goToPage" data-page="/pages/exercise/exercise">
        <view class="stat-icon exercise-icon">🏃</view>
        <view class="stat-info">
          <view class="stat-value">{{todayExercise || '--'}}步</view>
          <view class="stat-label">运动</view>
        </view>
      </view>
      <view class="stat-card" bindtap="goToPage" data-page="/pages/water/water">
        <view class="stat-icon water-icon">💧</view>
        <view class="stat-info">
          <view class="stat-value">{{waterProgress}}%</view>
          <view class="stat-label">喝水</view>
        </view>
      </view>
    </view>

    <view class="stats-grid" wx:if="{{healthStatus === 'sick'}}">
      <view class="stat-card" bindtap="goToPage" data-page="/pages/temperature/temperature">
        <view class="stat-icon temp-icon">🌡️</view>
        <view class="stat-info">
          <view class="stat-value">{{todayTemp || '--'}}°C</view>
          <view class="stat-label">体温</view>
        </view>
      </view>
      <view class="stat-card" bindtap="goToPage" data-page="/pages/medicine/medicine">
        <view class="stat-icon medicine-icon">💊</view>
        <view class="stat-info">
          <view class="stat-value">{{medicineCount}}</view>
          <view class="stat-label">待服药</view>
        </view>
      </view>
    </view>

    <view class="section-title">今日提醒</view>
    <view class="reminder-header">
      <text class="reminder-title">今日待办</text>
      <view class="add-reminder-btn" bindtap="showAddReminderModal">+ 添加提醒</view>
    </view>
    <view class="reminder-list">
      <view class="reminder-item" wx:for="{{allReminders}}" wx:key="id">
        <view class="reminder-icon">{{item.type === 'medicine' ? '💊' : '📝'}}</view>
        <view class="reminder-time">{{item.time}}</view>
        <view class="reminder-content">
          <text class="reminder-drug">{{item.drugName || item.content}}</text>
          <text class="reminder-dosage" wx:if="{{item.dosage}}">{{item.dosage}}片</text>
        </view>
        <view class="reminder-btn {{item.done ? 'taken' : ''}}" bindtap="completeReminder" data-id="{{item.id}}" data-type="{{item.type}}">
          {{item.done || item.taken ? '已完成' : '完成'}}
        </view>
      </view>
      <view class="empty-reminder" wx:if="{{allReminders.length === 0}}">
        暂无提醒，点击上方按钮添加
      </view>
    </view>

    <view class="section-title">快速打卡</view>
    <view class="quick-actions">
      <view class="action-btn {{healthStatus === 'sick' ? 'disabled' : ''}}" bindtap="addWater" wx:if="{{healthStatus === 'normal'}}">
        <view class="action-icon">💧</view>
        <view class="action-text">喝水</view>
      </view>
      <view class="action-btn {{healthStatus === 'sick' ? 'disabled' : ''}}" bindtap="addExercise" wx:if="{{healthStatus === 'normal'}}">
        <view class="action-icon">🏃</view>
        <view class="action-text">运动</view>
      </view>
      <view class="action-btn {{healthStatus === 'normal' ? 'disabled' : ''}}" bindtap="addTemperature" wx:if="{{healthStatus === 'sick'}}">
        <view class="action-icon">🌡️</view>
        <view class="action-text">体温</view>
      </view>
      <view class="action-btn {{healthStatus === 'normal' ? 'disabled' : ''}}" bindtap="addWeight" wx:if="{{healthStatus === 'sick'}}">
        <view class="action-icon">⚖️</view>
        <view class="action-text">体重</view>
      </view>
    </view>

    <view class="modal-overlay" wx:if="{{showReminderModal}}" bindtap="hideReminderModal">
      <view class="modal-content-top" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">添加提醒</text>
          <view class="modal-close" bindtap="hideReminderModal">×</view>
        </view>
        <view class="modal-body">
          <view class="form-item">
            <text class="form-label">提醒内容</text>
            <input class="form-input" placeholder="请输入提醒内容" value="{{newReminder.content}}" bindinput="onReminderInput" />
          </view>
          <view class="form-item">
            <text class="form-label">提醒时间</text>
            <picker mode="time" value="{{newReminder.time}}" bindchange="onReminderTimeChange">
              <view class="form-picker">
                {{newReminder.time || '请选择时间'}}
              </view>
            </picker>
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-secondary" bindtap="hideReminderModal">取消</button>
          <button class="btn-primary" bindtap="saveReminder">保存</button>
        </view>
      </view>
    </view>
  </view>
  <tab-bar current-page="/pages/index/index"></tab-bar>
</view>