.current-section {
  margin-bottom: 32rpx;
}

.current-card {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
  border-radius: 24rpx;
  padding: 32rpx;
}

.current-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.weight-value {
  font-size: 80rpx;
  font-weight: 300;
  color: #ffffff;
}

.weight-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.current-info {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.info-row {
  text-align: center;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.info-value.gain {
  color: #ef5350;
}

.info-value.loss {
  color: #66bb6a;
}

.info-value.even {
  color: #ffffff;
}

.input-section {
  margin-bottom: 32rpx;
}

.input-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.input-display {
  display: flex;
  align-items: baseline;
  flex-direction: column;
}

.input-edit {
  font-size: 24rpx;
  color: #4CAF50;
  margin-top: 8rpx;
}

.input-value {
  font-size: 56rpx;
  font-weight: 300;
  color: #333333;
}

.input-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.input-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-minus,
.btn-plus {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
}

.btn-minus {
  background: #ffebee;
  color: #f44336;
}

.btn-plus {
  background: #e8f5e9;
  color: #4CAF50;
}

.btn-add {
  width: 100%;
  padding: 20rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 20rpx 0;
}

.chart-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-container {
  height: 340rpx;
  position: relative;
}

.chart {
  width: 100%;
  height: 100%;
}

.chart-tips {
  text-align: center;
  padding-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.record-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  flex: 2;
  font-size: 26rpx;
  color: #999999;
}

.record-weight {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.record-change {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
}

.record-change.up {
  color: #f44336;
}

.record-change.down {
  color: #4CAF50;
}

.record-change.same {
  color: #999999;
}

.record-delete {
  color: #f44336;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #f44336;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.empty-record {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

.main-content {
  padding-bottom: 120rpx;
}