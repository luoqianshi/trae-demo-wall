.profile-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-motto {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.stats-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 16rpx 0;
}

.settings-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.settings-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #999999;
}

.item-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.data-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.data-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.data-item:last-child {
  border-bottom: none;
}

.data-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.data-icon.temp {
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
}

.data-icon.weight {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
}

.data-icon.water {
  background: linear-gradient(135deg, #B3E5FC 0%, #81D4FA 100%);
}

.data-icon.exercise {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.data-icon.medicine {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}

.data-info {
  flex: 1;
}

.data-title {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.data-count {
  font-size: 24rpx;
  color: #999999;
}

.about-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.about-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.about-item:last-child {
  border-bottom: none;
}

.about-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.about-text {
  font-size: 30rpx;
  color: #333333;
}

.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #999999;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 500rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  text-align: center;
}

.status-options {
  display: flex;
  justify-content: space-around;
}

.status-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  margin: 0 16rpx;
}

.status-option.selected {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.status-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
}

.main-content {
  padding-bottom: 120rpx;
}