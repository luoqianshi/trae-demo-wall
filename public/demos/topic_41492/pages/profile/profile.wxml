<view class="container">
  <view class="main-content">
    <view class="profile-header">
      <view class="avatar">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <view class="user-name">{{userName}}</view>
        <view class="user-motto">健康生活，从点滴开始</view>
      </view>
      <view class="edit-btn" bindtap="editProfile">编辑</view>
    </view>

    <view class="stats-card">
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-value">{{totalDays}}</view>
          <view class="stat-label">记录天数</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{totalRecords}}</view>
          <view class="stat-label">总记录数</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{streakDays}}</view>
          <view class="stat-label">连续天数</view>
        </view>
      </view>
    </view>

    <view class="section-title">快捷设置</view>
    <view class="settings-list">
      <view class="settings-item" bindtap="goToWeightTarget">
        <view class="item-icon">⚖️</view>
        <view class="item-content">
          <view class="item-title">目标体重</view>
          <view class="item-desc">当前目标: {{targetWeight}}kg</view>
        </view>
        <view class="item-arrow">›</view>
      </view>
      <view class="settings-item" bindtap="goToHealthStatus">
        <view class="item-icon">{{healthStatus === 'normal' ? '😊' : '🤒'}}</view>
        <view class="item-content">
          <view class="item-title">健康状态</view>
          <view class="item-desc">{{healthStatus === 'normal' ? '健康' : '生病中'}}</view>
        </view>
        <view class="item-arrow">›</view>
      </view>
    </view>

    <view class="section-title">我的数据</view>
    <view class="data-list">
      <view class="data-item" bindtap="goToPage" data-page="/pages/temperature/temperature">
        <view class="data-icon temp">🌡️</view>
        <view class="data-info">
          <view class="data-title">体温记录</view>
          <view class="data-count">{{tempCount}} 条</view>
        </view>
      </view>
      <view class="data-item" bindtap="goToPage" data-page="/pages/weight/weight">
        <view class="data-icon weight">⚖️</view>
        <view class="data-info">
          <view class="data-title">体重记录</view>
          <view class="data-count">{{weightCount}} 条</view>
        </view>
      </view>
      <view class="data-item" bindtap="goToPage" data-page="/pages/water/water">
        <view class="data-icon water">💧</view>
        <view class="data-info">
          <view class="data-title">喝水记录</view>
          <view class="data-count">{{waterCount}} 条</view>
        </view>
      </view>
      <view class="data-item" bindtap="goToExercise">
        <view class="data-icon exercise">🏃</view>
        <view class="data-info">
          <view class="data-title">运动记录</view>
          <view class="data-count">{{exerciseCount}} 条</view>
        </view>
      </view>
      <view class="data-item" bindtap="goToPage" data-page="/pages/medicine/medicine">
        <view class="data-icon medicine">💊</view>
        <view class="data-info">
          <view class="data-title">用药提醒</view>
          <view class="data-count">{{medicineCount}} 条</view>
        </view>
      </view>
    </view>

    <view class="section-title">关于我们</view>
    <view class="about-list">
      <view class="about-item" bindtap="showAbout">
        <view class="about-icon">ℹ️</view>
        <view class="about-text">关于轻养记</view>
      </view>
      <view class="about-item" bindtap="clearData">
        <view class="about-icon">🗑️</view>
        <view class="about-text">清空数据</view>
      </view>
    </view>

    <view class="version-info">
      轻养记 v1.0.0
    </view>

    <view class="modal-overlay" wx:if="{{showTargetModal}}" bindtap="hideTargetModal">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">设置目标体重</text>
          <view class="modal-close" bindtap="hideTargetModal">×</view>
        </view>
        <view class="modal-body">
          <view class="form-item">
            <input class="form-input" type="number" placeholder="请输入目标体重(kg)" value="{{targetWeight}}" bindinput="onTargetInput" />
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-secondary" bindtap="hideTargetModal">取消</button>
          <button class="btn-primary" bindtap="saveTarget">保存</button>
        </view>
      </view>
    </view>

    <view class="modal-overlay" wx:if="{{showStatusModal}}" bindtap="hideStatusModal">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">设置健康状态</text>
          <view class="modal-close" bindtap="hideStatusModal">×</view>
        </view>
        <view class="modal-body">
          <view class="status-options">
            <view class="status-option {{healthStatus === 'normal' ? 'selected' : ''}}" bindtap="setStatus" data-status="normal">
              <view class="status-icon">😊</view>
              <view class="status-text">健康</view>
            </view>
            <view class="status-option {{healthStatus === 'sick' ? 'selected' : ''}}" bindtap="setStatus" data-status="sick">
              <view class="status-icon">🤒</view>
              <view class="status-text">生病中</view>
            </view>
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-primary" bindtap="confirmStatus">确认</button>
        </view>
      </view>
    </view>
  </view>
  <tab-bar current-page="/pages/profile/profile"></tab-bar>
</view>