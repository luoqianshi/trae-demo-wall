<view class="container">
  <view class="main-content">
    <view class="input-card">
      <view class="input-label">当前体温</view>
      <view class="input-display">
        <text class="temp-value">{{currentTemp}}</text>
        <text class="temp-unit">°C</text>
      </view>
      <view class="temp-slider">
        <slider 
          min="35" 
          max="42" 
          step="0.1" 
          value="{{tempSliderValue}}" 
          activeColor="#4CAF50"
          backgroundColor="#e0e0e0"
          block-size="24"
          bindchange="onTempChange"
        />
        <view class="slider-labels">
          <text>35°C</text>
          <text>42°C</text>
        </view>
      </view>
      <button class="btn-primary btn-add" bindtap="addRecord">记录体温</button>
    </view>

    <view class="status-card">
      <view class="status-item">
        <view class="status-icon">{{getTempIcon(currentTemp)}}</view>
        <view class="status-info">
          <view class="status-text">{{getTempStatus(currentTemp)}}</view>
          <view class="status-desc">{{getTempDesc(currentTemp)}}</view>
        </view>
      </view>
    </view>

    <view class="section-title">今日体温</view>
    <view class="chart-card" wx:if="{{todayRecords.length >= 2}}">
      <view class="chart-container">
        <canvas canvas-id="tempChart" class="chart"></canvas>
      </view>
      <view class="chart-tips">
        今日体温变化趋势
      </view>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{todayRecords}}" wx:key="id">
        <view class="record-time">{{item.createTime}}</view>
        <view class="record-temp {{getTempClass(item.value)}}">
          {{item.value}}°C
        </view>
        <view class="record-status">
          {{getTempStatus(item.value)}}
        </view>
      </view>
      <view class="empty-record" wx:if="{{todayRecords.length === 0}}">
        暂无今日记录
      </view>
    </view>

    <view class="section-title">历史记录</view>
    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-date">{{item.createTime}}</view>
        <view class="record-temp {{getTempClass(item.value)}}">
          {{item.value}}°C
        </view>
        <view class="record-status">
          {{getTempStatus(item.value)}}
        </view>
        <view class="record-delete" bindtap="deleteRecord" data-id="{{item.id}}">删除</view>
      </view>
      <view class="empty-record" wx:if="{{records.length === 0}}">
        暂无历史记录
      </view>
    </view>
  </view>
  <tab-bar current-page="/pages/temperature/temperature"></tab-bar>
</view>