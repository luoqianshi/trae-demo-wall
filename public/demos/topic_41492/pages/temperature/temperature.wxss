.add-section {
  margin-bottom: 32rpx;
}

.input-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.input-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 32rpx;
}

.temp-value {
  font-size: 96rpx;
  font-weight: 300;
  color: #333333;
}

.temp-unit {
  font-size: 32rpx;
  color: #999999;
  margin-left: 8rpx;
}

.temp-slider {
  padding: 0 20rpx;
  margin-bottom: 32rpx;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.btn-add {
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 20rpx 0;
}

.status-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.status-item {
  display: flex;
  align-items: center;
}

.status-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #999999;
}

.record-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  flex: 2;
  font-size: 26rpx;
  color: #666666;
}

.record-date {
  flex: 2;
}

.date-text {
  font-size: 26rpx;
  color: #999999;
}

.record-temp {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.temp-normal {
  color: #4CAF50;
}

.temp-low {
  color: #2196F3;
}

.temp-fever {
  color: #ff9800;
}

.temp-high {
  color: #f44336;
}

.record-status {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
}

.empty-record {
  text-align: center;
  padding: 60rpx;
  color: #999999;
  font-size: 28rpx;
}

.chart-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-container {
  height: 300rpx;
  position: relative;
}

.chart {
  width: 100%;
  height: 100%;
}

.chart-tips {
  text-align: center;
  padding-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.record-delete {
  color: #f44336;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #f44336;
  border-radius: 8rpx;
  margin-left: 16rpx;
}