.progress-section {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
}

.progress-ring {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-right: 32rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e0e0e0;
}

.ring-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, #000 56%);
  -webkit-mask: radial-gradient(transparent 55%, #000 56%);
}

.ring-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.progress-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.progress-unit {
  font-size: 20rpx;
  color: #666666;
}

.progress-info {
  flex: 1;
}

.progress-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.progress-target {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar .bar-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.quick-add {
  display: flex;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.add-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
  margin: 0 8rpx;
}

.add-btn.custom {
  background: #E3F2FD;
}

.add-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 20rpx 0;
}

.record-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 26rpx;
  color: #999999;
}

.record-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.empty-record {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

.week-chart {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-container {
  width: 40rpx;
  height: 160rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.bar-container .bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 100%);
  border-radius: 8rpx;
  min-height: 4rpx;
}

.bar-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666666;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 500rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  text-align: center;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
}

.main-content {
  padding-bottom: 120rpx;
}