<view class="container">
  <view class="main-content">
    <view class="progress-section">
    <view class="progress-ring">
      <view class="ring-bg"></view>
      <view class="ring-progress" style="background: conic-gradient(#4CAF50 0deg, #4CAF50 {{progressAngle}}deg, #e0e0e0 {{progressAngle}}deg, #e0e0e0 360deg)"></view>
      <view class="ring-inner">
        <text class="progress-value">{{todayTotal}}</text>
        <text class="progress-unit">ml</text>
      </view>
    </view>
    <view class="progress-info">
      <view class="progress-text">今日已喝</view>
      <view class="progress-target">目标: 2000ml</view>
      <view class="progress-bar">
        <view class="bar-fill" style="width: {{progressPercent}}%"></view>
      </view>
    </view>
  </view>

  <view class="quick-add">
    <view class="add-btn" bindtap="addWater" data-amount="200">
      <view class="add-icon">💧</view>
      <view class="add-text">200ml</view>
    </view>
    <view class="add-btn" bindtap="addWater" data-amount="300">
      <view class="add-icon">💧💧</view>
      <view class="add-text">300ml</view>
    </view>
    <view class="add-btn" bindtap="addWater" data-amount="500">
      <view class="add-icon">💧💧💧</view>
      <view class="add-text">500ml</view>
    </view>
    <view class="add-btn custom" bindtap="showCustomModal">
      <view class="add-icon">+</view>
      <view class="add-text">自定义</view>
    </view>
  </view>

  <view class="section-title">今日记录</view>
  <view class="record-list">
    <view class="record-item" wx:for="{{todayRecords}}" wx:key="id">
      <view class="record-time">{{item.createTime}}</view>
      <view class="record-amount">+{{item.amount}}ml</view>
    </view>
    <view class="empty-record" wx:if="{{todayRecords.length === 0}}">
      暂无记录，点击上方按钮开始打卡
    </view>
  </view>

  <view class="section-title">本周统计</view>
  <view class="week-chart">
    <view class="chart-bar" wx:for="{{weekData}}" wx:key="day">
      <view class="bar-container">
        <view class="bar-fill" style="height: {{item.percent}}%"></view>
      </view>
      <view class="bar-label">{{item.day}}</view>
      <view class="bar-value">{{item.total}}ml</view>
    </view>
  </view>

  <view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">自定义饮水量</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <input class="form-input" type="number" placeholder="请输入饮水量(ml)" value="{{customAmount}}" bindinput="onCustomInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn-primary" bindtap="addCustomWater">确认</button>
      </view>
    </view>
  </view>
  </view>
  <tab-bar current-page="/pages/water/water"></tab-bar>
</view>