<view class="container">
  <view class="main-content">
    <view class="stats-section">
      <view class="stat-item">
        <view class="stat-value">{{todaySteps}}</view>
        <view class="stat-label">今日步数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{todayDistance}}km</view>
        <view class="stat-label">距离</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{todayCalories}}</view>
        <view class="stat-label">消耗(kcal)</view>
      </view>
    </view>

    <view class="progress-section">
      <view class="progress-card">
        <view class="progress-header">
          <text class="progress-title">今日目标</text>
          <text class="progress-percent">{{stepProgress}}%</text>
        </view>
        <view class="progress-ring-large">
          <view class="ring-bg"></view>
          <view class="ring-progress" style="background: conic-gradient(#4CAF50 0deg, #4CAF50 {{stepAngle}}deg, #e0e0e0 {{stepAngle}}deg, #e0e0e0 360deg)"></view>
          <view class="ring-inner">
            <text class="ring-value">{{todaySteps}}</text>
            <text class="ring-target">/ 10000</text>
          </view>
        </view>
        <view class="progress-text">
          {{stepProgress >= 100 ? '🎉 已超目标 ' + (todaySteps - 10000) + ' 步！' : '还需 ' + (10000 - todaySteps) + ' 步完成目标'}}
        </view>
      </view>
    </view>

    <view class="quick-add">
      <view class="add-btn" bindtap="addExercise" data-steps="1000">
        <view class="add-icon">🚶</view>
        <view class="add-text">1000步</view>
      </view>
      <view class="add-btn" bindtap="addExercise" data-steps="3000">
        <view class="add-icon">🏃</view>
        <view class="add-text">3000步</view>
      </view>
      <view class="add-btn" bindtap="addExercise" data-steps="5000">
        <view class="add-icon">🏃‍♂️</view>
        <view class="add-text">5000步</view>
      </view>
      <view class="add-btn custom" bindtap="showCustomModal">
        <view class="add-icon">+</view>
        <view class="add-text">自定义</view>
      </view>
    </view>

    <view class="section-title">本周统计</view>
    <view class="week-stats">
      <view class="week-item" wx:for="{{weekStats}}" wx:key="day">
        <view class="week-bar-container">
          <view class="week-bar-fill" style="height: {{item.percent}}%"></view>
        </view>
        <view class="week-label">{{item.day}}</view>
        <view class="week-value">{{item.steps}}</view>
      </view>
    </view>

    <view class="section-title">历史记录</view>
    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-date">{{item.createTime}}</view>
        <view class="record-steps">{{item.steps}}步</view>
        <view class="record-calories">{{Math.round(item.steps * 0.04)}}kcal</view>
        <view class="record-delete" bindtap="deleteRecord" data-id="{{item.id}}">删除</view>
      </view>
      <view class="empty-record" wx:if="{{records.length === 0}}">
        暂无运动记录
      </view>
    </view>

    <view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">自定义步数</text>
          <view class="modal-close" bindtap="hideModal">×</view>
        </view>
        <view class="modal-body">
          <view class="form-item">
            <input class="form-input" type="number" placeholder="请输入步数" value="{{customSteps}}" bindinput="onCustomInput" />
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-secondary" bindtap="hideModal">取消</button>
          <button class="btn-primary" bindtap="addCustomExercise">确认</button>
        </view>
      </view>
    </view>
  </view>
  <tab-bar current-page="/pages/exercise/exercise"></tab-bar>
</view>