/* ============================================
   静途小程序 - 全局样式表 v4.0
   支持浅色(light)/深色(dark)双主题
   ============================================ */

/* ==================== 页面基础样式（必须保留） ==================== */
page {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--theme-text-primary);
  background-color: var(--theme-bg);
}

/* ==================== 主题变量 - 浅色主题（默认） ==================== */
.page {
  /* 页面背景 */
  --theme-bg: #F4FAF7;
  --theme-bg-secondary: #FFFFFF;
  --theme-bg-tertiary: #FAFBFA;
  --theme-bg-card: #FFFFFF;
  --theme-bg-input: #F4FAF7;
  --theme-bg-hover: #E8F5EC;
  --theme-bg-active: #D4EDDA;
  
  /* 文字颜色 */
  --theme-text-primary: #1C3A2C;
  --theme-text-secondary: #5A6B62;
  --theme-text-muted: #7E8C85;
  --theme-text-placeholder: #97A8A0;
  --theme-text-inverse: #FFFFFF;
  
  /* 主色调 - 绿色护眼 */
  --theme-color-primary: #0F9D58;
  --theme-color-primary-light: #27AE60;
  --theme-color-primary-dark: #0B7A45;
  --theme-color-secondary: #4285F4;
  --theme-color-accent: #34A853;
  
  /* 功能色 */
  --theme-color-success: #0F9D58;
  --theme-color-warning: #F5A623;
  --theme-color-danger: #E74C3C;
  --theme-color-info: #4285F4;
  
  /* 边框 */
  --theme-border: #E0E8E2;
  --theme-border-light: #F0F4F0;
  --theme-border-focus: #0F9D58;
  
  /* 阴影 */
  --theme-shadow: 0 4rpx 28rpx rgba(15, 157, 88, 0.08);
  --theme-shadow-sm: 0 2rpx 12rpx rgba(15, 157, 88, 0.05);
  --theme-shadow-lg: 0 8rpx 40rpx rgba(15, 157, 88, 0.12);
  
  /* 评分条 */
  --theme-score-bg: #E8F0FE;
  --theme-score-fill: linear-gradient(90deg, #0F9D58, #4285F4);
  
  /* 渐变背景 */
  --theme-gradient-primary: linear-gradient(135deg, #E6F7EC 0%, #E8F0FE 100%);
  --theme-gradient-hero: linear-gradient(135deg, #0F9D58 0%, #4285F4 100%);
  
  /* 标签背景 */
  --theme-tag-info-bg: #E8F0FE;
  --theme-tag-info-color: #4285F4;
  --theme-tag-pos-bg: #E6F7EC;
  --theme-tag-pos-color: #0F9D58;
  --theme-tag-warn-bg: #FDEDED;
  --theme-tag-warn-color: #C0453E;
  
  /* 输入框 */
  --theme-input-bg: #F4FAF7;
  --theme-input-border: transparent;
  --theme-input-border-focus: #0F9D58;
  --theme-input-text: #1C3A2C;
  --theme-input-placeholder: #97A8A0;
  
  /* 页面底部安全区 */
  --safe-area-inset-bottom: env(safe-area-inset-bottom);
}

/* ==================== 深色主题覆盖 ==================== */
/* 深色模式：背景变暗、文字变白、绿色按钮降低亮度护眼 */
.page.theme-dark {
  /* 页面背景 - 深色系 */
  --theme-bg: #1A1F1C;
  --theme-bg-secondary: #242A26;
  --theme-bg-tertiary: #2A332E;
  --theme-bg-card: #242A26;
  --theme-bg-input: #1E2520;
  --theme-bg-hover: #2A332E;
  --theme-bg-active: #354538;
  
  /* 文字颜色 - 高对比度白色系 */
  --theme-text-primary: #E8F0EC;
  --theme-text-secondary: #B8C8BC;
  --theme-text-muted: #8A9A8E;
  --theme-text-placeholder: #6A7A6E;
  --theme-text-inverse: #1A1F1C;
  
  /* 深色模式下绿色调低亮度护眼 - 降低饱和度避免刺眼 */
  --theme-color-primary: #4CAF7A;
  --theme-color-primary-light: #5DBF8C;
  --theme-color-primary-dark: #3D8F62;
  --theme-color-secondary: #6B9FFF;
  --theme-color-accent: #5DBF8C;
  
  /* 功能色 */
  --theme-color-success: #4CAF7A;
  --theme-color-warning: #FFB74D;
  --theme-color-danger: #EF5350;
  --theme-color-info: #6B9FFF;
  
  /* 边框 - 深色边框 */
  --theme-border: #3A453E;
  --theme-border-light: #2E382E;
  --theme-border-focus: #4CAF7A;
  
  /* 阴影 - 深色阴影 */
  --theme-shadow: 0 4rpx 28rpx rgba(0, 0, 0, 0.3);
  --theme-shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
  --theme-shadow-lg: 0 8rpx 40rpx rgba(0, 0, 0, 0.4);
  
  /* 评分条 - 深色背景 */
  --theme-score-bg: #2A332E;
  --theme-score-fill: linear-gradient(90deg, #4CAF7A, #6B9FFF);
  
  /* 渐变背景 - 深色渐变 */
  --theme-gradient-primary: linear-gradient(135deg, #2A3A30 0%, #2A3340 100%);
  --theme-gradient-hero: linear-gradient(135deg, #2A3A30 0%, #2A3340 100%);
  
  /* 标签背景 - 深色标签 */
  --theme-tag-info-bg: #2A3340;
  --theme-tag-info-color: #6B9FFF;
  --theme-tag-pos-bg: #2A3A30;
  --theme-tag-pos-color: #4CAF7A;
  --theme-tag-warn-bg: #3A2A2A;
  --theme-tag-warn-color: #EF5350;
  
  /* 输入框 - 深色输入框 */
  --theme-input-bg: #1E2520;
  --theme-input-border: #3A453E;
  --theme-input-border-focus: #4CAF7A;
  --theme-input-text: #E8F0EC;
  --theme-input-placeholder: #6A7A6E;
}

/* ==================== 基础布局 ==================== */
.page {
  min-height: 100vh;
  background-color: var(--theme-bg);
  padding-bottom: calc(160rpx + var(--safe-area-inset-bottom));
}

.page-wrap {
  padding: 0 0 40rpx;
}

/* ==================== Hero 区域 ==================== */
.hero {
  background: var(--theme-gradient-hero);
  padding: 60rpx 40rpx 80rpx;
  position: relative;
}

.hero-inner {
  text-align: center;
}

.hero-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-brand-main {
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 8rpx;
}

.hero-brand-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 12rpx;
  margin-top: 8rpx;
}

.hero-slogan {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.hero-badges {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 主题切换按钮 */
.theme-toggle {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #FFFFFF;
  backdrop-filter: blur(10rpx);
}

.theme-toggle-icon {
  font-size: 32rpx;
  line-height: 1;
}

.theme-toggle-text {
  font-size: 18rpx;
  color: #FFFFFF;
  text-align: center;
  line-height: 1.2;
  margin-top: 2rpx;
}

/* 深色模式下主题切换按钮 */
page.theme-dark .theme-toggle {
  background: rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* ==================== 通用卡片 ==================== */
.card {
  background: var(--theme-bg-card);
  border-radius: 32rpx;
  padding: 36rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: var(--theme-shadow);
  transition: background-color 0.3s, box-shadow 0.3s;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title-bar {
  width: 8rpx;
  height: 32rpx;
  background: var(--theme-score-fill);
  border-radius: 6rpx;
  margin-right: 16rpx;
  display: inline-block;
  flex-shrink: 0;
}

/* ==================== 选项按钮 ==================== */
.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  background: var(--theme-bg-input);
  border: 2rpx solid var(--theme-border);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--theme-text-secondary);
  cursor: pointer;
  transition: all 0.2s ease;
  min-height: 72rpx;
  box-sizing: border-box;
}

.option-item:active {
  transform: scale(0.97);
}

.option-item.active {
  background: var(--theme-bg-active);
  color: var(--theme-color-primary);
  border-color: var(--theme-color-primary);
  font-weight: 600;
}

.option-item.disabled {
  background: var(--theme-bg-tertiary);
  color: var(--theme-text-muted);
  border-color: var(--theme-border-light);
  opacity: 0.5;
  pointer-events: none;
}

.option-item.active-risk {
  background: var(--theme-tag-warn-bg);
  color: var(--theme-color-danger);
  border-color: var(--theme-tag-warn-color);
}

.option-item.repair-item {
  background: var(--theme-bg-tertiary);
  color: var(--theme-text-muted);
  border-color: var(--theme-border);
}

.option-item.active-repair {
  background: var(--theme-tag-pos-bg);
  color: var(--theme-color-success);
  border-color: var(--theme-color-success);
}

.toggle-arrow {
  margin-left: auto;
  font-size: 20rpx;
  color: var(--theme-text-muted);
}

/* ==================== 输入框标准化 ==================== */
.field-input {
  display: block;
  width: 100%;
  min-height: 80rpx;
  line-height: 1.5;
  background: var(--theme-input-bg);
  border: 2rpx solid var(--theme-input-border);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--theme-input-text);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.3s;
  caret-color: var(--theme-color-primary);
}

.field-input:focus {
  border-color: var(--theme-input-border-focus);
  outline: none;
}

.field-input[placeholder],
.field-input::placeholder {
  color: var(--theme-input-placeholder);
}

.field-textarea {
  display: block;
  width: 100%;
  min-height: 180rpx;
  line-height: 1.6;
  background: var(--theme-input-bg);
  border: 2rpx solid var(--theme-input-border);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--theme-input-text);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.3s;
  caret-color: var(--theme-color-primary);
}

.field-textarea:focus {
  border-color: var(--theme-input-border-focus);
  outline: none;
}

.field-textarea[placeholder],
.field-textarea::placeholder {
  color: var(--theme-input-placeholder);
}

/* 输入框相关布局 */
.field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.field-row .field-input-small {
  flex: 1;
  min-height: 80rpx;
  line-height: 1.5;
  text-align: center;
  background: var(--theme-input-bg);
  border: 2rpx solid var(--theme-input-border);
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: var(--theme-input-text);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.3s;
}

.field-row .field-input-small:focus {
  border-color: var(--theme-input-border-focus);
  outline: none;
}

.field-row .field-input-small[placeholder],
.field-row .field-input-small::placeholder {
  color: var(--theme-input-placeholder);
}

.field-sep {
  color: var(--theme-text-muted);
  font-size: 28rpx;
  padding: 0 8rpx;
  flex-shrink: 0;
}

/* 自定义里程输入区 */
.custom-distance {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  background: var(--theme-input-bg);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  gap: 16rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--theme-border);
}

.custom-distance .field-input {
  background: var(--theme-bg-secondary);
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  min-height: 64rpx;
  padding: 16rpx 20rpx;
  border: none;
}

.distance-prefix,
.distance-unit {
  color: var(--theme-text-muted);
  font-size: 26rpx;
  flex-shrink: 0;
}

/* ==================== 按钮样式 ==================== */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx;
  padding: 28rpx 40rpx;
  background: var(--theme-gradient-hero);
  color: var(--theme-text-inverse);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: var(--theme-shadow);
  transition: transform 0.2s, box-shadow 0.2s, opacity 0.3s;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: var(--theme-shadow-sm);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background: var(--theme-bg-input);
  border: 2rpx solid var(--theme-border);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--theme-text-secondary);
  transition: all 0.2s ease;
}

.btn-ghost:active {
  background: var(--theme-bg-hover);
  border-color: var(--theme-color-primary);
  color: var(--theme-color-primary);
}

.action-btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background: var(--theme-color-primary);
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--theme-text-inverse);
  transition: all 0.2s ease;
}

.action-btn-primary:active {
  background: var(--theme-color-primary-dark);
  transform: scale(0.97);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.reset-btn {
  display: inline-block;
  padding: 18rpx 40rpx;
  border-radius: 44rpx;
  background: var(--theme-tag-warn-bg);
  color: var(--theme-color-danger);
  font-size: 26rpx;
  font-weight: 600;
  border: 2rpx solid var(--theme-tag-warn-color);
  text-align: center;
  transition: background-color 0.2s;
}

.reset-btn:active {
  background: var(--theme-bg-hover);
}

/* ==================== 评分条 ==================== */
.score-block {
  margin: 20rpx 0;
}

.score-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.score-label {
  width: 100rpx;
  font-size: 24rpx;
  color: var(--theme-text-secondary);
  flex-shrink: 0;
}

.score-bar {
  flex: 1;
  height: 16rpx;
  background: var(--theme-score-bg);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.score-bar-inner {
  height: 100%;
  background: var(--theme-score-fill);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.score-value {
  width: 48rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--theme-color-primary);
  flex-shrink: 0;
}

/* ==================== 标签 ==================== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.tag-info {
  background: var(--theme-tag-info-bg);
  color: var(--theme-tag-info-color);
}

.tag-pos {
  background: var(--theme-tag-pos-bg);
  color: var(--theme-tag-pos-color);
}

.tag-warn {
  background: var(--theme-tag-warn-bg);
  color: var(--theme-tag-warn-color);
}

/* ==================== 摘要与提示 ==================== */
.summary {
  text-align: center;
  padding: 20rpx 32rpx;
  margin: 0 32rpx;
  background: var(--theme-bg-input);
  border-radius: 20rpx;
  border: 2rpx solid var(--theme-border);
}

.summary-label {
  font-size: 24rpx;
  color: var(--theme-text-muted);
}

.summary-text {
  font-size: 26rpx;
  color: var(--theme-text-primary);
  font-weight: 500;
}

.text-muted {
  color: var(--theme-text-muted);
}

.text-small {
  font-size: 24rpx;
}

.hint-card {
  background: var(--theme-gradient-primary);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.hint-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--theme-color-primary);
  margin-bottom: 12rpx;
}

.hint-text {
  font-size: 26rpx;
  color: var(--theme-text-secondary);
  line-height: 1.6;
}

.tip-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--theme-text-muted);
  padding: 0 32rpx 32rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--theme-text-muted);
  font-size: 28rpx;
}

.empty-text {
  text-align: center;
  padding: 24rpx;
  color: var(--theme-text-muted);
  font-size: 26rpx;
}

/* ==================== 模板卡片 ==================== */
.template-card {
  background: var(--theme-gradient-primary);
}

.template-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.template-item {
  flex: 1;
  min-width: calc(50% - 8rpx);
  max-width: calc(50% - 8rpx);
  background: var(--theme-bg-card);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border: 2rpx solid var(--theme-border);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.template-item:active {
  transform: scale(0.97);
}

.template-item.active {
  background: var(--theme-gradient-primary);
  border-color: var(--theme-color-primary);
  box-shadow: var(--theme-shadow-sm);
}

.template-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.template-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
  margin-bottom: 4rpx;
}

.template-desc {
  font-size: 20rpx;
  color: var(--theme-text-muted);
}

.template-hint {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: var(--theme-bg-active);
  border-radius: 16rpx;
}

.template-hint-text {
  font-size: 24rpx;
  color: var(--theme-color-primary);
  font-weight: 500;
}

/* ==================== 白噪音模块 ==================== */
.noise-card {
  background: var(--theme-gradient-primary);
}

.noise-grid {
  display: flex;
  gap: 16rpx;
}

.noise-item {
  flex: 1;
  background: var(--theme-bg-card);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid var(--theme-border);
  transition: all 0.2s ease;
}

.noise-item:active {
  transform: scale(0.97);
}

.noise-item.active {
  background: var(--theme-gradient-primary);
  border-color: var(--theme-color-primary);
  box-shadow: var(--theme-shadow-sm);
}

.noise-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.noise-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--theme-text-primary);
  margin-bottom: 4rpx;
}

.noise-status {
  font-size: 20rpx;
  color: var(--theme-text-muted);
}

.noise-control {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed var(--theme-border);
}

.noise-volume {
  padding: 0 16rpx;
}

.noise-label {
  font-size: 24rpx;
  color: var(--theme-text-muted);
  margin-bottom: 12rpx;
  display: block;
}

.noise-stop {
  text-align: center;
  padding: 16rpx;
  background: var(--theme-tag-warn-bg);
  border-radius: 16rpx;
  color: var(--theme-color-danger);
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* ==================== 路线统计 ==================== */
.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  background: var(--theme-bg-tertiary);
  border-radius: 16rpx;
}

.stat-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
}

.stat-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--theme-text-muted);
  margin-left: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--theme-text-muted);
  margin-top: 4rpx;
}

/* ==================== 随笔 ==================== */
.note-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

/* ==================== 推荐列表 ==================== */
.pref-card {
  background: var(--theme-bg-card);
  padding: 32rpx;
  margin: 0;
  box-shadow: var(--theme-shadow-sm);
}

.pref-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
  margin-bottom: 12rpx;
}

.pref-sub {
  font-size: 24rpx;
  color: var(--theme-text-muted);
  margin-bottom: 20rpx;
}

.route-card {
  background: var(--theme-bg-card);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: var(--theme-shadow);
  transition: background-color 0.3s;
}

.route-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.route-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.route-rank {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-color-primary);
  background: var(--theme-bg-active);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.route-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
  flex: 1;
}

.ugc-tag {
  font-size: 20rpx;
  color: var(--theme-color-secondary);
  background: var(--theme-tag-info-bg);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.score-chip {
  background: var(--theme-gradient-hero);
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  flex-shrink: 0;
}

.score-chip-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.score-chip-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.route-meta {
  font-size: 26rpx;
  color: var(--theme-text-secondary);
  margin-bottom: 16rpx;
}

.dot {
  margin: 0 8rpx;
  color: var(--theme-text-muted);
}

.route-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.route-stat-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: var(--theme-bg-tertiary);
  border-radius: 20rpx;
}

.route-stat-icon {
  font-size: 24rpx;
}

.route-stat-value {
  font-size: 24rpx;
  color: var(--theme-text-secondary);
  font-weight: 500;
}

.ai-reason {
  background: var(--theme-bg-tertiary);
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 16rpx 0;
}

.ai-reason-label {
  font-size: 22rpx;
  color: var(--theme-color-secondary);
  margin-bottom: 8rpx;
}

.ai-reason-text {
  font-size: 24rpx;
  color: var(--theme-text-secondary);
  line-height: 1.6;
}

/* AI推荐卡片（支持主题） */
.ai-reason-card {
  background: var(--theme-tag-info-bg) !important;
  border: 2rpx dashed var(--theme-border) !important;
}

.route-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  justify-content: flex-end;
}

.bottom-upload {
  background: var(--theme-bg-card);
  padding: 24rpx 32rpx;
  margin: 24rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx dashed var(--theme-border);
  text-align: center;
}

.bottom-upload-text {
  font-size: 26rpx;
  color: var(--theme-text-secondary);
}

/* ==================== 路线详情 ==================== */
.detail-head {
  background: var(--theme-gradient-hero);
  padding: 48rpx 40rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.detail-meta {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.detail-meta-sub {
  color: rgba(255, 255, 255, 0.6);
}

.mock-map {
  padding: 20rpx 0;
}

.map-node {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
}

.map-node::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 40rpx;
  width: 2rpx;
  height: calc(100% + 4rpx);
  background: var(--theme-border);
}

.map-node:last-child::before {
  display: none;
}

.map-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--theme-bg-tertiary);
  border: 2rpx solid var(--theme-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--theme-text-muted);
  margin-right: 16rpx;
  flex-shrink: 0;
  z-index: 1;
}

.map-dot.start {
  background: var(--theme-color-success);
  border-color: var(--theme-color-success);
  color: #FFFFFF;
}

.map-dot.end {
  background: var(--theme-color-danger);
  border-color: var(--theme-color-danger);
  color: #FFFFFF;
}

.map-label {
  flex: 1;
}

.map-label-text {
  font-size: 26rpx;
  color: var(--theme-text-primary);
}

.bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: var(--theme-bg-card);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 20rpx var(--theme-shadow-sm);
}

/* ==================== 上报页 ==================== */
.report-head {
  background: var(--theme-gradient-primary);
}

.report-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--theme-text-primary);
  margin-bottom: 8rpx;
}

.report-sub {
  font-size: 26rpx;
  color: var(--theme-text-secondary);
}

.star-line {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--theme-border-light);
}

.star-line:last-child {
  border-bottom: none;
}

.star-label {
  width: 120rpx;
  font-size: 28rpx;
  color: var(--theme-text-primary);
}

.stars {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.star {
  font-size: 44rpx;
  color: var(--theme-border);
  transition: color 0.2s;
}

.star.on {
  color: #FFD700;
}

.star-num {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--theme-color-primary);
}

/* ==================== 上传页 ==================== */
.upload-section {
  margin-bottom: 32rpx;
}

.upload-hero {
  background: var(--theme-gradient-hero);
  padding: 48rpx 40rpx;
  text-align: center;
}

.upload-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.upload-hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 故事页 ==================== */
.story-header {
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
  background: var(--theme-gradient-hero);
}

.story-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.story-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.story-card {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.story-icon {
  font-size: 48rpx;
  line-height: 1;
  flex-shrink: 0;
}

.story-content {
  flex: 1;
}

.story-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--theme-text-primary);
  margin-bottom: 12rpx;
}

.story-card-desc {
  font-size: 26rpx;
  color: var(--theme-text-secondary);
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.story-highlight {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: var(--theme-gradient-primary);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--theme-color-primary);
  font-weight: 600;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.image-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-image-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  border: 2rpx dashed var(--theme-border);
  border-radius: 20rpx;
  background: var(--theme-bg-tertiary);
}

.add-icon {
  font-size: 48rpx;
  color: var(--theme-text-muted);
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: var(--theme-text-muted);
}

.story-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx calc(60rpx + var(--safe-area-inset-bottom));
}

.footer-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--theme-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--theme-shadow-sm);
}

.footer-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--theme-text-secondary);
}

/* ==================== 底部导航 ==================== */
.quick-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding: 20rpx 32rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: var(--theme-bg-input);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--theme-text-secondary);
  border: 2rpx solid var(--theme-border);
}

.quick-emoji {
  font-size: 28rpx;
}

.reset-wrap {
  display: flex;
  justify-content: center;
  margin: 36rpx 32rpx 0;
}

/* 页面底部说明 */
.footer-note {
  text-align: center;
  color: var(--theme-text-muted);
  font-size: 22rpx;
  padding: 28rpx 40rpx;
  line-height: 1.8;
}

/* ==================== 工具类 ==================== */
.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.gap-16 {
  gap: 16rpx;
}
