<!-- pages/upload/upload.wxml —— 上传私藏路线 -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <view class="upload-hero">
    <view class="upload-hero-title">📮 分享你的私藏路线</view>
    <view class="upload-hero-sub">让更多运动爱好者，走你走过的好路</view>
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>路线名称</view>
    <input
      class="field-input"
      placeholder="例如：清晨河边 3km 私藏路线"
      value="{{form.name}}"
      data-key="name"
      bindinput="onInput" />
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>里程 / 耗时</view>
    <view class="field-row">
      <input
        class="field-input field-input-small"
        type="digit"
        placeholder="里程(km)"
        value="{{form.distance}}"
        data-key="distance"
        bindinput="onInput" />
      <view class="field-sep">×</view>
      <input
        class="field-input field-input-small"
        type="number"
        placeholder="耗时(分钟)"
        value="{{form.duration}}"
        data-key="duration"
        bindinput="onInput" />
    </view>
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>适合的运动类型（多选）</view>
    <view class="option-row">
      <view
        wx:for="{{sportOptions}}"
        wx:key="value"
        class="option-item {{item.selected ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onToggleSport">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>推荐时段（多选）</view>
    <view class="option-row">
      <view
        wx:for="{{timeOptions}}"
        wx:key="value"
        class="option-item {{item.selected ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onToggleTime">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>路线标签（多选）</view>
    <view class="option-row">
      <view
        wx:for="{{tagOptions}}"
        wx:key="value"
        class="option-item {{item.selected ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onToggleTag">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title"><view class="section-title-bar"></view>路线说明</view>
    <textarea
      class="field-textarea"
      placeholder="简单描述一下这条路线的亮点（比如：沿路安静、有便利店、风景好等）"
      value="{{form.desc}}"
      maxlength="200"
      data-key="desc"
      bindinput="onInput" />
  </view>

  <view class="btn-primary" bindtap="onSubmit">✨ 发布私藏路线</view>

  <view class="footer-note">你的分享会进入全民共建路线池，并出现在其他用户的推荐结果中。</view>
</view>
