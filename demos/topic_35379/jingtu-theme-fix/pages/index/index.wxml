<!-- pages/index/index.wxml —— 静途首页 -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <!-- 顶部 Hero -->
  <view class="hero">
    <!-- 主题切换按钮 -->
    <view class="theme-toggle" bindtap="onToggleTheme">
      <view class="theme-toggle-icon">{{themeIcon}}</view>
      <view class="theme-toggle-text">{{themeText}}</view>
    </view>
    
    <view class="hero-inner">
      <view class="hero-brand">
        <text class="hero-brand-main">静途</text>
        <text class="hero-brand-sub">JING · TU</text>
      </view>
      <view class="hero-slogan">找到更安静、更安全的城市运动路线</view>
      <view class="hero-badges">
        <view class="hero-badge">🌿 低车流</view>
        <view class="hero-badge">🌙 分时段</view>
        <view class="hero-badge">🤖 AI 推荐</view>
      </view>
    </view>
  </view>

  <view class="page-wrap">
    <!-- 目标里程 -->
    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>目标里程</view>
      <view class="option-row">
        <view
          wx:for="{{distanceOptions}}"
          wx:key="value"
          class="option-item {{item.value === selectedDistance ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectDistance">
          {{item.label}}
        </view>
      </view>
      <view class="custom-distance">
        <text class="distance-prefix">自定义</text>
        <input
          class="field-input"
          type="digit"
          value="{{customDistance}}"
          placeholder="例如 4.5"
          bindinput="onCustomDistanceInput" />
        <text class="distance-unit">km</text>
      </view>
    </view>

    <!-- 运动类型 -->
    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>运动类型</view>
      <view class="option-row">
        <view
          wx:for="{{sportOptions}}"
          wx:key="value"
          class="option-item {{item.value === selectedSport ? 'active' : ''}} {{disabledSports.indexOf(item.value) >= 0 ? 'disabled' : ''}}"
          data-value="{{item.value}}"
          bindtap="disabledSports.indexOf(item.value) >= 0 ? '' : 'onSelectSport'">
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 运动时段 -->
    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>运动时段</view>
      <view class="option-row">
        <view
          wx:for="{{timeOptions}}"
          wx:key="value"
          class="option-item {{item.value === selectedTime ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectTime">
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 我的偏好 -->
    <view class="card">
      <view class="section-title"><view class="section-title-bar"></view>我的偏好</view>
      <view class="option-row">
        <view
          wx:for="{{priorityOptions}}"
          wx:key="value"
          class="option-item {{item.value === selectedPriority ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectPriority">
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 一键人群预设模板（新增） -->
    <view class="card template-card">
      <view class="section-title"><view class="section-title-bar"></view>一键人群预设</view>
      <view class="template-grid">
        <view
          wx:for="{{templateOptions}}"
          wx:key="id"
          class="template-item {{item.id === selectedTemplate ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSelectTemplate">
          <view class="template-icon">{{item.icon}}</view>
          <view class="template-name">{{item.name}}</view>
          <view class="template-desc">{{item.desc}}</view>
        </view>
      </view>
      <view wx:if="{{selectedTemplate}}" class="template-hint">
        <text class="template-hint-text">已选择「{{templateHint}}」模板，AI 将自动调整权重与扣分规则</text>
      </view>
    </view>

    <!-- 当前选择摘要 -->
    <view class="summary">
      <text class="summary-label">当前选择：</text>
      <text class="summary-text">{{summaryText}}</text>
    </view>

    <!-- AI 生成按钮 -->
    <view class="btn-primary" bindtap="onGenerate">✨ AI 生成路线</view>

    <!-- 底部快捷入口 -->
    <view class="quick-row">
      <view class="quick-item" bindtap="onGoUpload">
        <text class="quick-emoji">📮</text>上传私藏路线
      </view>
      <view class="quick-item" bindtap="onShowIntro">
        <text class="quick-emoji">💡</text>关于"全民共建"
      </view>
    </view>

    <!-- 白噪音陪伴模块 -->
    <view class="card noise-card">
      <view class="section-title"><view class="section-title-bar"></view>🎵 慢行陪伴</view>
      <view class="noise-grid">
        <view
          wx:for="{{noiseOptions}}"
          wx:key="id"
          class="noise-item {{item.id === currentNoise ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onToggleNoise">
          <view class="noise-icon">{{item.icon}}</view>
          <view class="noise-name">{{item.name}}</view>
          <view class="noise-status">{{item.id === currentNoise ? '播放中' : '点击播放'}}</view>
        </view>
      </view>
      <view wx:if="{{currentNoise}}" class="noise-control">
        <view class="noise-volume">
          <text class="noise-label">音量</text>
          <slider
            value="{{noiseVolume}}"
            min="0"
            max="100"
            activeColor="{{themeColors.sliderActive}}"
            backgroundColor="{{themeColors.sliderBackground}}"
            block-size="24"
            bindchange="onNoiseVolumeChange" />
        </view>
        <view class="noise-stop" bindtap="onStopNoise">⏹ 停止播放</view>
      </view>
    </view>

    <!-- 独立重置按钮（修复 #3：与说明文字分离，避免误触） -->
    <view class="reset-wrap">
      <view class="reset-btn" bindtap="onReset">🗑 重置演示数据</view>
    </view>

    <view class="footer-note">
      静途 · AI 创造力大赛初赛作品 · 小程序演示版
    </view>
  </view>
</view>
