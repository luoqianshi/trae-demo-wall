<!-- pages/recommend/recommend.wxml —— AI 推荐列表 -->
<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <!-- 用户当前选择摘要 -->
  <view class="pref-card">
    <view class="pref-title">{{prefTitle}}</view>
    <view class="pref-sub">🤖 AI 基于你的偏好与全民上报，为你重排路线</view>
    <view class="btn-ghost" bindtap="onRefresh">🔄 重新计算</view>
  </view>

  <view class="page-wrap">
    <block wx:if="{{routeList.length > 0}}">
      <view
        class="route-card"
        wx:for="{{routeList}}"
        wx:for-item="route"
        wx:key="id">
        <view class="route-head">
          <view class="route-name-row">
            <view class="route-rank">#{{index + 1}}</view>
            <view class="route-name">{{route.name}}</view>
            <view wx:if="{{route.isUserUpload}}" class="ugc-tag">用户共建</view>
          </view>
          <view class="score-chip">
            <text class="score-chip-num">{{route.recommendScore}}</text>
            <text class="score-chip-label">推荐分</text>
          </view>
        </view>

        <view class="route-meta">
          🚶 {{route.distanceKm}}km
          <text class="dot">·</text>
          ⏱ 约 {{route.durationMin}} 分钟
        </view>
        
        <!-- 路线统计（替换竞速数据） -->
        <view class="route-stats">
          <view class="route-stat-item">
            <text class="route-stat-icon">🌙</text>
            <text class="route-stat-value">{{route.stats.quietMinutes}}分</text>
          </view>
          <view class="route-stat-item">
            <text class="route-stat-icon">🌿</text>
            <text class="route-stat-value">{{route.stats.greenRate}}%</text>
          </view>
          <view class="route-stat-item">
            <text class="route-stat-icon">🚶</text>
            <text class="route-stat-value">{{route.stats.avgSpeed}}km/h</text>
          </view>
        </view>

        <view class="tag-row">
          <view
            wx:for="{{route.surfaceTypes}}"
            wx:for-item="surface"
            wx:key="*this"
            class="tag tag-info">{{surface}}</view>
        </view>

        <!-- 四维评分条 -->
        <view class="score-block">
          <view
            wx:for="{{route.dimScores}}"
            wx:for-item="dim"
            wx:key="key"
            class="score-row">
            <view class="score-label">{{dim.label}}</view>
            <view class="score-bar">
              <view class="score-bar-inner" style="width:{{dim.value}}%;"></view>
            </view>
            <view class="score-value">{{dim.value}}</view>
          </view>
        </view>

        <!-- 路线标签 -->
        <view wx:if="{{route.tags.length > 0}}" class="tag-row">
          <view
            wx:for="{{route.tags}}"
            wx:for-item="tagItem"
            wx:key="*this"
            class="tag tag-pos">{{tagItem}}</view>
        </view>

        <!-- 风险反馈 -->
        <view wx:if="{{route.riskReports.length > 0}}" class="tag-row">
          <view
            wx:for="{{route.riskReports}}"
            wx:for-item="riskItem"
            wx:key="*this"
            class="tag tag-warn">⚠ {{riskItem}}</view>
        </view>

        <!-- AI 解释 -->
        <view class="ai-reason">
          <view class="ai-reason-label">🤖 AI 推荐理由</view>
          <view class="ai-reason-text">{{route.aiReason}}</view>
        </view>

        <view class="route-actions">
          <view class="btn-ghost" data-id="{{route.id}}" bindtap="onGoDetail">查看详情</view>
          <view class="action-btn-primary" data-id="{{route.id}}" bindtap="onGoReport">去评分上报</view>
        </view>
      </view>
    </block>

    <view wx:else class="empty">暂无匹配的路线，试试修改首页的偏好</view>
  </view>

  <view class="bottom-upload" bindtap="onGoUpload">
    <view class="bottom-upload-text">📮 上传你的私藏路线，全民共建更好走的路线</view>
  </view>

  <view class="footer-note">推荐算法 = 距离匹配分 + 运动/时段命中 + 四维评分×偏好权重 − 风险扣分</view>
</view>
