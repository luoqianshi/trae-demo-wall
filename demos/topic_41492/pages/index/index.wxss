.status-switch {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.switch-content {
  display: flex;
  align-items: center;
}

.switch-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  transition: transform 0.3s ease;
}

.switch-icon.normal {
  transform: scale(1);
}

.switch-icon.sick {
  transform: scale(1.1);
}

.switch-text {
  flex: 1;
}

.mode-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: #999999;
}

.switch-toggle {
  margin-left: 20rpx;
}

.toggle-track {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e0e0e0;
  padding: 4rpx;
  transition: all 0.3s ease;
  position: relative;
}

.toggle-track.normal {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}

.toggle-track.sick {
  background: linear-gradient(135deg, #f44336 0%, #e57373 100%);
}

.toggle-thumb {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
}

.toggle-thumb.normal {
  left: 4rpx;
}

.toggle-thumb.sick {
  left: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 20rpx 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.temp-icon {
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
}

.weight-icon {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
}

.water-icon {
  background: linear-gradient(135deg, #B3E5FC 0%, #81D4FA 100%);
}

.exercise-icon {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.medicine-icon {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
}

.stat-info {
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.add-reminder-btn {
  font-size: 26rpx;
  color: #4CAF50;
  padding: 8rpx 16rpx;
  border: 2rpx solid #4CAF50;
  border-radius: 20rpx;
}

.reminder-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.reminder-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.reminder-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  width: 120rpx;
}

.reminder-content {
  flex: 1;
  display: flex;
  align-items: center;
}

.reminder-drug {
  font-size: 28rpx;
  color: #333333;
  margin-right: 12rpx;
}

.reminder-dosage {
  font-size: 24rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.reminder-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #4CAF50;
  color: #ffffff;
}

.reminder-btn.taken {
  background: #e0e0e0;
  color: #999999;
}

.empty-reminder {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

.empty-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.action-btn.disabled {
  opacity: 0.4;
}

.main-content {
  padding-bottom: 120rpx;
}