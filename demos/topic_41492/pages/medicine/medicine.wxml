<view class="container">
  <view class="main-content">
    <view class="add-section">
      <button class="btn-primary btn-add" bindtap="showAddModal">+ 添加用药提醒</button>
    </view>

    <view class="section-title">今日待服用</view>
    <view class="reminder-list">
      <view class="reminder-card" wx:for="{{todayReminders}}" wx:key="id">
        <view class="reminder-header">
          <view class="reminder-time">
            <text class="time-icon">🕐</text>
            <text class="time-text">{{item.time}}</text>
          </view>
          <view class="reminder-status {{item.taken ? 'taken' : ''}}">
            {{item.taken ? '已服用' : '待服用'}}
          </view>
        </view>
        <view class="reminder-body">
          <view class="drug-name">{{item.drugName}}</view>
          <view class="drug-info">
            <text class="info-item">剂量: {{item.dosage}}片</text>
            <text class="info-item">频次: {{item.frequency}}</text>
          </view>
        </view>
        <button class="reminder-btn {{item.taken ? 'btn-disabled' : ''}}" bindtap="takeMedicine" data-id="{{item.id}}" disabled="{{item.taken}}">
          {{item.taken ? '已服用' : '确认服用'}}
        </button>
      </view>
      <view class="empty-state" wx:if="{{todayReminders.length === 0}}">
        <view class="empty-icon">💊</view>
        <view class="empty-text">今日暂无用药提醒</view>
      </view>
    </view>

    <view class="section-title">全部提醒</view>
    <view class="medicine-list">
      <view class="medicine-card" wx:for="{{reminders}}" wx:key="id">
        <view class="medicine-header">
          <view class="medicine-name">{{item.drugName}}</view>
          <view class="medicine-time">{{item.time}}</view>
        </view>
        <view class="medicine-details">
          <view class="detail-row">
            <text class="detail-label">剂量</text>
            <text class="detail-value">{{item.dosage}}片/次</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">频次</text>
            <text class="detail-value">{{item.frequency}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">备注</text>
            <text class="detail-value">{{item.note || '无'}}</text>
          </view>
        </view>
        <view class="medicine-actions">
          <view class="action-btn edit" bindtap="editReminder" data-id="{{item.id}}">编辑</view>
          <view class="action-btn delete" bindtap="deleteReminder" data-id="{{item.id}}">删除</view>
        </view>
      </view>
      <view class="empty-state" wx:if="{{reminders.length === 0}}">
        <view class="empty-icon">📝</view>
        <view class="empty-text">暂无用药提醒</view>
        <view class="empty-hint">点击上方按钮添加提醒</view>
      </view>
    </view>

    <view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
      <view class="modal-content-long" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">{{editingId ? '编辑提醒' : '添加用药提醒'}}</text>
          <view class="modal-close" bindtap="hideModal">×</view>
        </view>
        <view class="modal-body">
          <view class="form-item">
            <text class="form-label">药品名称</text>
            <input class="form-input" placeholder="请输入药品名称" value="{{formData.drugName}}" bindinput="onFormInput" data-field="drugName" />
          </view>
          <view class="form-item">
            <text class="form-label">服用时间</text>
            <picker mode="time" value="{{formData.time}}" bindchange="onTimeChange">
              <view class="form-picker">
                {{formData.time || '请选择时间'}}
              </view>
            </picker>
          </view>
          <view class="form-item">
            <text class="form-label">剂量（片）</text>
            <input class="form-input" type="number" placeholder="请输入剂量" value="{{formData.dosage}}" bindinput="onFormInput" data-field="dosage" />
          </view>
          <view class="form-item">
            <text class="form-label">服用频次</text>
            <picker mode="selector" range="{{frequencyOptions}}" range-key="label" value="{{frequencyIndex}}" bindchange="onFrequencyChange">
              <view class="form-picker">
                {{frequencyOptions[frequencyIndex] ? frequencyOptions[frequencyIndex].label : '请选择频次'}}
              </view>
            </picker>
          </view>
          <view class="form-item">
            <text class="form-label">备注</text>
            <input class="form-input" placeholder="选填，如：饭后服用" value="{{formData.note}}" bindinput="onFormInput" data-field="note" />
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-secondary" bindtap="hideModal">取消</button>
          <button class="btn-primary" bindtap="saveReminder">保存</button>
        </view>
      </view>
    </view>
  </view>
  <tab-bar current-page="/pages/medicine/medicine"></tab-bar>
</view>