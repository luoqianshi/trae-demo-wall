.add-section {
  margin-bottom: 32rpx;
}

.btn-add {
  width: 100%;
  padding: 28rpx;
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 32rpx 0 20rpx 0;
}

.reminder-list {
  margin-bottom: 16rpx;
}

.reminder-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reminder-time {
  display: flex;
  align-items: center;
}

.time-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.time-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.reminder-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #fff3e0;
  color: #ff9800;
}

.reminder-status.taken {
  background: #e8f5e9;
  color: #4CAF50;
}

.reminder-body {
  margin-bottom: 20rpx;
}

.drug-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.drug-info {
  display: flex;
  gap: 24rpx;
}

.info-item {
  font-size: 24rpx;
  color: #999999;
}

.reminder-btn {
  width: 100%;
  padding: 20rpx;
  background: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.reminder-btn.btn-disabled {
  background: #e0e0e0;
  color: #999999;
}

.medicine-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.medicine-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.medicine-card:last-child {
  border-bottom: none;
}

.medicine-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.medicine-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.medicine-time {
  font-size: 26rpx;
  color: #4CAF50;
}

.medicine-details {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999999;
}

.detail-value {
  font-size: 26rpx;
  color: #333333;
}

.medicine-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.action-btn.edit {
  background: #f5f5f5;
  color: #666666;
}

.action-btn.delete {
  background: #ffebee;
  color: #f44336;
}

.empty-state {
  text-align: center;
  padding: 60rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 24rpx 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
}

.main-content {
  padding-bottom: 120rpx;
}