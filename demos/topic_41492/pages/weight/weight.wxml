<view class="container">
  <view class="main-content">
    <view class="current-section">
    <view class="current-card">
      <view class="current-value">
        <text class="weight-value">{{currentWeight || '--'}}</text>
        <text class="weight-unit">kg</text>
      </view>
      <view class="current-info">
        <view class="info-row" bindtap="editTargetWeight">
          <text class="info-label">目标体重</text>
          <text class="info-value">{{targetWeight || '--'}}kg</text>
          <text class="info-arrow">›</text>
        </view>
        <view class="info-row">
          <text class="info-label">距目标</text>
          <text class="info-value {{diffColor}}">{{weightDiff > 0 ? '+' : ''}}{{weightDiff}}kg</text>
        </view>
      </view>
    </view>
  </view>

  <view class="input-section">
    <view class="input-card">
      <view class="input-label">记录体重</view>
      <view class="input-row">
        <view class="input-display" bindtap="showWeightInput">
          <text class="input-value">{{inputWeight}}</text>
          <text class="input-unit">kg</text>
          <text class="input-edit">点击修改</text>
        </view>
        <view class="input-buttons">
          <view class="btn-minus" bindtap="adjustWeight" data-step="-0.1">-</view>
          <view class="btn-plus" bindtap="adjustWeight" data-step="0.1">+</view>
        </view>
      </view>
      <button class="btn-primary btn-add" bindtap="addRecord">记录</button>
    </view>
  </view>

  <view class="section-title">体重趋势</view>
  <view class="chart-card">
    <view class="chart-container">
      <canvas canvas-id="weightChart" class="chart"></canvas>
    </view>
    <view class="chart-tips">
      近7天体重变化趋势
    </view>
  </view>

  <view class="section-title">历史记录</view>
  <view class="record-list">
    <view class="record-item" wx:for="{{records}}" wx:key="id">
      <view class="record-date">{{formatDate(item.createTime)}}</view>
      <view class="record-weight">{{item.value}}kg</view>
      <view class="record-change">
        {{getChange(item.id)}}
      </view>
      <view class="record-delete" bindtap="deleteRecord" data-id="{{item.id}}">删除</view>
    </view>
    <view class="empty-record" wx:if="{{records.length === 0}}">
      暂无体重记录
    </view>
  </view>

  <view class="modal-overlay" wx:if="{{showTargetModal}}" bindtap="hideTargetModal">
    <view class="modal-content-top" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改目标体重</text>
        <view class="modal-close" bindtap="hideTargetModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">目标体重 (kg)</text>
          <input class="form-input" type="digit" placeholder="请输入目标体重" value="{{editTargetWeight}}" bindinput="onTargetInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideTargetModal">取消</button>
        <button class="btn-primary" bindtap="saveTargetWeight">保存</button>
      </view>
    </view>
  </view>

  <view class="modal-overlay" wx:if="{{showWeightModal}}" bindtap="hideWeightModal">
    <view class="modal-content-top" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">输入体重</text>
        <view class="modal-close" bindtap="hideWeightModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">体重 (kg)</text>
          <input class="form-input" type="digit" placeholder="请输入体重" value="{{editInputWeight}}" bindinput="onWeightInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideWeightModal">取消</button>
        <button class="btn-primary" bindtap="saveWeightInput">确定</button>
      </view>
    </view>
  </view>
  </view>
  <tab-bar current-page="/pages/weight/weight"></tab-bar>
</view>