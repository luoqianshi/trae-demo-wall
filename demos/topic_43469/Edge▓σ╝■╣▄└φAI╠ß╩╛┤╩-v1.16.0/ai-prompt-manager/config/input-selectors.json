{
  "description": "AI 网站聊天输入框选择器配置，每个网站提供多个备选选择器，按优先级从高到低排列",
  "sites": [
    {
      "name": "ChatGPT",
      "domains": ["chatgpt.com", "chat.openai.com"],
      "selectors": [
        "div#prompt-textarea.ProseMirror[contenteditable='true']",
        "div.ProseMirror[contenteditable='true']",
        "div[contenteditable='true'][data-placeholder]",
        "textarea#prompt-textarea",
        "form[data-type='unified-composer'] [contenteditable='true']"
      ],
      "type": "contenteditable"
    },
    {
      "name": "Claude",
      "domains": ["claude.ai"],
      "selectors": [
        "div.ProseMirror[contenteditable='true']",
        "div[contenteditable='true'][data-testid='chat-input']",
        "div[contenteditable='true'] p[data-placeholder]",
        "div[contenteditable='true'][role='textbox']"
      ],
      "type": "contenteditable"
    },
    {
      "name": "Gemini",
      "domains": ["gemini.google.com", "bard.google.com"],
      "selectors": [
        "rich-textarea .ql-editor[contenteditable='true']",
        ".ql-editor[aria-label='Enter a prompt here']",
        ".ql-editor.textarea",
        "div[contenteditable='true'][role='textbox'][aria-label='Enter a prompt here']",
        ".text-input-field_textarea .ql-editor"
      ],
      "type": "contenteditable"
    },
    {
      "name": "Kimi",
      "domains": ["kimi.moonshot.cn", "www.kimi.com", "kimi.com"],
      "selectors": [
        "div.chat-input-editor[contenteditable='true']",
        "#chat-box div.chat-input-editor",
        "div.chat-input-editor-container div[contenteditable='true']",
        "[role='textbox'].chat-input-editor",
        "[role='textbox']",
        "div[contenteditable='true']"
      ],
      "type": "contenteditable"
    },
    {
      "name": "文心一言",
      "domains": ["yiyan.baidu.com", "yingyan.baidu.com"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "通义千问",
      "domains": ["tongyi.aliyun.com", "www.qianwen.com", "qianwen.com"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "讯飞星火",
      "domains": ["xinghuo.xfyun.cn"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "豆包",
      "domains": ["www.doubao.com", "doubao.com"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "智谱清言",
      "domains": ["chatglm.cn", "www.chatglm.cn"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "Copilot",
      "domains": ["copilot.microsoft.com", "www.bing.com/chat"],
      "selectors": [
        "textarea#searchbox",
        "textarea[placeholder]",
        "div[contenteditable='true']",
        "[role='textbox']"
      ],
      "type": "auto"
    },
    {
      "name": "Poe",
      "domains": ["poe.com"],
      "selectors": [
        "textarea[placeholder]",
        "div[contenteditable='true']",
        "[class*='ChatMessageInput'] textarea",
        "[role='textbox']"
      ],
      "type": "auto"
    },
    {
      "name": "DeepSeek",
      "domains": ["chat.deepseek.com", "www.deepseek.com"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "Perplexity",
      "domains": ["www.perplexity.ai", "perplexity.ai"],
      "selectors": [
        "textarea[placeholder]",
        "div[contenteditable='true']",
        "[role='textbox']"
      ],
      "type": "auto"
    },
    {
      "name": "天工AI",
      "domains": ["www.tiangong.cn", "tiangong.cn"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    },
    {
      "name": "腾讯元宝",
      "domains": ["yuanbao.tencent.com", "www.yuanbao.tencent.com"],
      "selectors": [
        "[role='textbox']",
        "div[contenteditable='true']",
        "textarea[placeholder]",
        "textarea"
      ],
      "type": "auto"
    }
  ],
  "universalFallback": {
    "selectors": [
      "[role='textbox']",
      "div[contenteditable='true']",
      "textarea",
      "input[type='text']"
    ],
    "description": "当没有匹配到特定网站时使用的通用选择器"
  }
}
